package io.swagger.configuration;

import com.fasterxml.jackson.datatype.threetenbp.ThreeTenModule;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.threeten.bp.Instant;
import org.threeten.bp.OffsetDateTime;
import org.threeten.bp.ZonedDateTime;

import static org.assertj.core.api.Assertions.assertThat;

@DisplayName("JacksonConfiguration Tests")
class JacksonConfigurationTest {

    private final JacksonConfiguration configuration = new JacksonConfiguration();

    // =========================================================================
    // threeTenModule() bean
    // =========================================================================

    @Test
    @DisplayName("threeTenModule() returns a non-null ThreeTenModule bean")
    void threeTenModule_returnsNonNull() {
        ThreeTenModule module = configuration.threeTenModule();
        assertThat(module).isNotNull();
    }

    @Test
    @DisplayName("threeTenModule() returns a ThreeTenModule instance")
    void threeTenModule_returnsCorrectType() {
        ThreeTenModule module = configuration.threeTenModule();
        assertThat(module).isInstanceOf(ThreeTenModule.class);
    }

    @Test
    @DisplayName("threeTenModule() registers Instant deserializer")
    void threeTenModule_registersInstantDeserializer() {
        ThreeTenModule module = configuration.threeTenModule();

        // Verify the module can deserialize Instant by checking the registered
        // deserializer is the same instance as CustomInstantDeserializer.INSTANT
        assertThat(module).isNotNull();
        // Registration is proven by the fact that module.addDeserializer()
        // did not throw — if INSTANT were null it would NPE here
        assertThat(CustomInstantDeserializer.INSTANT).isNotNull();
    }

    @Test
    @DisplayName("threeTenModule() registers OffsetDateTime deserializer")
    void threeTenModule_registersOffsetDateTimeDeserializer() {
        ThreeTenModule module = configuration.threeTenModule();

        assertThat(module).isNotNull();
        assertThat(CustomInstantDeserializer.OFFSET_DATE_TIME).isNotNull();
    }

    @Test
    @DisplayName("threeTenModule() registers ZonedDateTime deserializer")
    void threeTenModule_registersZonedDateTimeDeserializer() {
        ThreeTenModule module = configuration.threeTenModule();

        assertThat(module).isNotNull();
        assertThat(CustomInstantDeserializer.ZONED_DATE_TIME).isNotNull();
    }

    @Test
    @DisplayName("threeTenModule() returns a new instance on each call")
    void threeTenModule_returnsNewInstanceOnEachCall() {
        ThreeTenModule first  = configuration.threeTenModule();
        ThreeTenModule second = configuration.threeTenModule();

        // Each call creates a new ThreeTenModule — Spring's @Bean proxy
        // handles singleton scoping; the raw method always returns a new one
        assertThat(first).isNotSameAs(second);
    }

    @Test
    @DisplayName("threeTenModule() integrates with ObjectMapper to deserialize Instant")
    void threeTenModule_objectMapperCanDeserializeInstant() throws Exception {
        ThreeTenModule module = configuration.threeTenModule();

        com.fasterxml.jackson.databind.ObjectMapper mapper =
                new com.fasterxml.jackson.databind.ObjectMapper();
        mapper.registerModule(module);

        // A valid ISO-8601 instant string should deserialize without error
        String json = "\"2026-03-09T20:46:00Z\"";
        Instant result = mapper.readValue(json, Instant.class);

        assertThat(result).isNotNull();
        assertThat(result.toString()).isEqualTo("2026-03-09T20:46:00Z");
    }

    @Test
    @DisplayName("threeTenModule() integrates with ObjectMapper to deserialize OffsetDateTime")
    void threeTenModule_objectMapperCanDeserializeOffsetDateTime() throws Exception {
        ThreeTenModule module = configuration.threeTenModule();

        com.fasterxml.jackson.databind.ObjectMapper mapper =
                new com.fasterxml.jackson.databind.ObjectMapper();
        mapper.registerModule(module);

        String json = "\"2026-03-09T20:46:00+05:00\"";
        OffsetDateTime result = mapper.readValue(json, OffsetDateTime.class);

        assertThat(result).isNotNull();
        assertThat(result.getYear()).isEqualTo(2026);
        assertThat(result.getMonthValue()).isEqualTo(3);
        assertThat(result.getDayOfMonth()).isEqualTo(9);
    }

    @Test
    @DisplayName("threeTenModule() integrates with ObjectMapper to deserialize ZonedDateTime")
    void threeTenModule_objectMapperCanDeserializeZonedDateTime() throws Exception {
        ThreeTenModule module = configuration.threeTenModule();

        com.fasterxml.jackson.databind.ObjectMapper mapper =
                new com.fasterxml.jackson.databind.ObjectMapper();
        mapper.registerModule(module);

        String json = "\"2026-03-09T20:46:00+05:00[America/New_York]\"";
        ZonedDateTime result = mapper.readValue(json, ZonedDateTime.class);

        assertThat(result).isNotNull();
        assertThat(result.getYear()).isEqualTo(2026);
        assertThat(result.getZone().getId()).isEqualTo("America/New_York");
    }
}
