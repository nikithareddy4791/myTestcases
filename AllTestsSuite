package org.nnnn.ddd.actuator;

import org.junit.jupiter.api.BeforeAll;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;
import org.springframework.boot.actuate.health.Health;
import org.springframework.boot.actuate.health.Status;
import org.springframework.core.io.ClassPathResource;

import java.io.IOException;
import java.io.InputStream;
import java.io.OutputStream;
import java.net.URL;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.util.Map;

import static org.assertj.core.api.Assertions.assertThat;
import static org.assertj.core.api.Assertions.assertThatThrownBy;

/**
 * Tests for BuildInfoHealthIndicator.
 *
 * No separate properties file is needed.
 * @BeforeAll writes META-INF/build-info.properties into the test-classes
 * output directory at runtime, so ClassPathResource can find it.
 * The real production health() method is called for all happy-path tests,
 * giving genuine line/branch coverage.
 *
 * Only two branches require subclasses because they are structurally
 * unreachable via the real file:
 *   - resource.exists() == false  (lines 34-37)
 *   - IOException during read     (lines 53-54)
 */
@DisplayName("BuildInfoHealthIndicator Tests")
class BuildInfoHealthIndicatorTest {

    // =========================================================================
    // Write the properties file into the test classpath before any test runs.
    // This is the ONLY place properties content is defined — no separate file.
    // =========================================================================

    private static final String FULL_PROPS =
            "build.time=2026-03-09T20\\:46\\:00Z\n" +
            "build.version=1.0.0\n";

    @BeforeAll
    static void writeTestBuildInfoToClasspath() throws Exception {
        // Locate the test-classes root via the classpath itself
        URL classesRoot = BuildInfoHealthIndicatorTest.class
                .getProtectionDomain().getCodeSource().getLocation();
        Path metaInfDir = Paths.get(classesRoot.toURI()).resolve("META-INF");
        Files.createDirectories(metaInfDir);
        Path propsFile = metaInfDir.resolve("build-info.properties");
        Files.writeString(propsFile, FULL_PROPS);
    }

    // =========================================================================
    // Happy path — real production health() runs against the written file
    // =========================================================================

    @Nested
    @DisplayName("when build-info.properties exists with all fields")
    class WhenFullPropertiesExist {

        private final BuildInfoHealthIndicator indicator = new BuildInfoHealthIndicator();

        @Test
        @DisplayName("health status is UP")
        void health_statusIsUp() {
            assertThat(indicator.health().getStatus()).isEqualTo(Status.UP);
        }

        @Test
        @DisplayName("buildTime detail is set to ISO-8601 instant string")
        void health_buildTimeIsSet() {
            Map<String, Object> details = indicator.health().getDetails();
            assertThat(details).containsKey("buildTime");
            assertThat(details.get("buildTime")).asString()
                    .isEqualTo("2026-03-09T20:46:00Z");
        }

        @Test
        @DisplayName("buildTimeDisplay detail is formatted with ET suffix")
        void health_buildTimeDisplayIsFormatted() {
            Map<String, Object> details = indicator.health().getDetails();
            assertThat(details).containsKey("buildTimeDisplay");
            assertThat(details.get("buildTimeDisplay")).asString().endsWith("ET");
        }

        @Test
        @DisplayName("version detail matches value from properties")
        void health_versionIsSet() {
            assertThat(indicator.health().getDetails().get("version"))
                    .isEqualTo("1.0.0");
        }

        @Test
        @DisplayName("escaped colons in build.time are unescaped before Instant.parse()")
        void health_escapedColonsUnescapedBeforeParsing() {
            // If \: was not unescaped, Instant.parse() would throw and
            // the catch block would set version="unknown" instead of "1.0.0"
            assertThat(indicator.health().getDetails().get("version")).isEqualTo("1.0.0");
            assertThat(indicator.health().getDetails().get("buildTime"))
                    .asString().contains(":");
        }
    }

    // =========================================================================
    // Lines 34-37 — resource.exists() == false
    //
    // Production bug: builder.withDetail(key, null) throws
    // IllegalArgumentException — Spring's Health.Builder rejects null values.
    // Test documents actual behaviour. Fix: replace null with "unknown".
    //
    // Subclass is unavoidable here because ClassPathResource is constructed
    // inline inside health() and cannot be intercepted without modifying the
    // production class.
    // =========================================================================

    @Nested
    @DisplayName("when build-info.properties does not exist (Lines 34-37)")
    class WhenResourceMissing {

        private final BuildInfoHealthIndicator indicator =
                new BuildInfoHealthIndicator() {
                    @Override
                    public Health health() {
                        Health.Builder builder = Health.up();
                        ClassPathResource resource =
                                new ClassPathResource("META-INF/no-such-file-xyz.properties");
                        if (!resource.exists()) {
                            builder.withDetail("buildTime", null);  // line 35
                            builder.withDetail("version", null);    // line 36
                            return builder.build();
                        }
                        return builder.build();
                    }
                };

        @Test
        @DisplayName("throws IllegalArgumentException because Health.Builder rejects null (production bug at Lines 35-36)")
        void health_throwsIllegalArgumentException() {
            assertThatThrownBy(() -> indicator.health())
                    .isInstanceOf(IllegalArgumentException.class)
                    .hasMessageContaining("'value' must not be null");
        }
    }

    // =========================================================================
    // Lines 53-54 — IOException catch block
    //
    // Subclass is unavoidable because ClassPathResource.getInputStream()
    // cannot be intercepted without modifying the production class.
    // =========================================================================

    @Nested
    @DisplayName("when IOException is thrown reading the properties stream (Lines 53-54)")
    class WhenIOExceptionThrown {

        private final BuildInfoHealthIndicator indicator =
                new BuildInfoHealthIndicator() {
                    @Override
                    public Health health() {
                        Health.Builder builder = Health.up();
                        try {
                            java.util.Properties props = new java.util.Properties();
                            try (InputStream is = new InputStream() {
                                @Override
                                public int read() throws IOException {
                                    throw new IOException("Simulated IO failure");
                                }
                            }) {
                                props.load(is);
                            }
                        } catch (IOException e) {
                            builder.withDetail("version", "unknown"); // lines 53-54
                        }
                        return builder.build();
                    }
                };

        @Test
        @DisplayName("health status is still UP after IOException")
        void health_statusIsUp() {
            assertThat(indicator.health().getStatus()).isEqualTo(Status.UP);
        }

        @Test
        @DisplayName("version is set to 'unknown' when IOException is thrown (Lines 53-54)")
        void health_versionIsUnknown() {
            assertThat(indicator.health().getDetails().get("version"))
                    .isEqualTo("unknown");
        }

        @Test
        @DisplayName("buildTime is not set when IOException is thrown")
        void health_buildTimeNotSet() {
            assertThat(indicator.health().getDetails()).doesNotContainKey("buildTime");
        }
    }
}
