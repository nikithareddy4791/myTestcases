    // =========================================================================
    // Lines 288-289 — filter lambda: entityTag.getTag() != null
    //                 && dtoTag.getTagId().intValue() == entityTag.getTag().getId()
    //
    // This lambda has two sub-branches:
    //   A) entityTag.getTag() == null   → filter returns false (tag skipped)
    //   B) entityTag.getTag() != null
    //      && tagId matches              → filter returns true  (tag reused, Line 302)
    //   C) entityTag.getTag() != null
    //      && tagId does NOT match       → filter returns false (new tag created)
    // =========================================================================

    @Test
    @DisplayName("saveCase - filter skips entityTag when getTag() is null (Line 288 false branch)")
    void saveCase_existingTagWithNullTagReference_createsNewTag() {
        dtoCase.setId(100);

        // Entity has a CaseTag whose tag reference is null (orphaned row)
        CaseTag orphanTag = new CaseTag();
        orphanTag.setId(99);
        orphanTag.setTag(null);                     // ← entityTag.getTag() == null
        entityCase.getTags().add(orphanTag);

        org.nnnn.ddd.model.CaseTag dtoTag = new org.nnnn.ddd.model.CaseTag();
        dtoTag.setTagId(5);
        dtoCase.setTags(List.of(dtoTag));

        TagList tagEntity = new TagList();
        tagEntity.setId(5);

        stubFindById(100);
        when(tagListRepository.findById(5)).thenReturn(Optional.of(tagEntity));

        caseService.saveCase(dtoCase);

        // A new CaseTag was created because the orphan was filtered out
        verify(tagListRepository).findById(5);
        assertThat(entityCase.getTags()).hasSize(1);
        assertThat(entityCase.getTags().iterator().next().getTag()).isEqualTo(tagEntity);
    }

    @Test
    @DisplayName("saveCase - filter matches existing tag by id and reuses it (Lines 288-289, Line 302)")
    void saveCase_existingTagMatchesById_reusesExistingTag() {
        dtoCase.setId(100);

        // Entity already has a CaseTag for tag id=7
        TagList existingTagList = new TagList();
        existingTagList.setId(7);
        CaseTag existingCaseTag = new CaseTag();
        existingCaseTag.setId(50);
        existingCaseTag.setTag(existingTagList);    // ← entityTag.getTag() != null
        entityCase.getTags().add(existingCaseTag);

        // DTO requests the same tag id=7
        org.nnnn.ddd.model.CaseTag dtoTag = new org.nnnn.ddd.model.CaseTag();
        dtoTag.setTagId(7);                         // ← matches existingTagList.getId()
        dtoCase.setTags(List.of(dtoTag));

        stubFindById(100);

        caseService.saveCase(dtoCase);

        // Line 302: updatedTags.add(foundTag.get()) — existing tag reused, no DB lookup
        verify(tagListRepository, never()).findById(anyInt());
        assertThat(entityCase.getTags()).hasSize(1);
        assertThat(entityCase.getTags().iterator().next()).isEqualTo(existingCaseTag);
    }

    @Test
    @DisplayName("saveCase - filter does not match when tag id differs (Lines 288-289 true then false on id)")
    void saveCase_existingTagWithDifferentId_createsNewTag() {
        dtoCase.setId(100);

        // Entity has tag id=3 but DTO wants tag id=9 — ids don't match
        TagList differentTagList = new TagList();
        differentTagList.setId(3);
        CaseTag existingCaseTag = new CaseTag();
        existingCaseTag.setTag(differentTagList);   // tag != null but id != 9
        entityCase.getTags().add(existingCaseTag);

        org.nnnn.ddd.model.CaseTag dtoTag = new org.nnnn.ddd.model.CaseTag();
        dtoTag.setTagId(9);
        dtoCase.setTags(List.of(dtoTag));

        TagList newTagEntity = new TagList();
        newTagEntity.setId(9);

        stubFindById(100);
        when(tagListRepository.findById(9)).thenReturn(Optional.of(newTagEntity));

        caseService.saveCase(dtoCase);

        // New tag created because id didn't match
        verify(tagListRepository).findById(9);
        assertThat(entityCase.getTags()).hasSize(1);
        assertThat(entityCase.getTags().iterator().next().getTag()).isEqualTo(newTagEntity);
    }

