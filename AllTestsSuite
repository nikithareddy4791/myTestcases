package org.nnnn.ddd.exceptions;

import org.junit.jupiter.api.Test;

import static org.junit.jupiter.api.Assertions.*;

/**
 * Covers the (String, Throwable) constructors for FileDeleteException,
 * CaseAccessException, and InvalidDluOfficeException — the three constructors
 * reported as missed branches in SonarQube.
 */
public class ExceptionClassesMissingTest {

    // -------------------------------------------------------------------------
    // FileDeleteException
    // -------------------------------------------------------------------------

    @Test
    void fileDeleteException_messageCauseConstructor_setsMessageAndCause() {
        Throwable cause = new RuntimeException("root cause");

        FileDeleteException ex = new FileDeleteException("Delete failed", cause);

        assertEquals("Delete failed", ex.getMessage());
        assertEquals(cause, ex.getCause());
    }

    // -------------------------------------------------------------------------
    // CaseAccessException
    // -------------------------------------------------------------------------

    @Test
    void caseAccessException_messageCauseConstructor_setsMessageAndCause() {
        Throwable cause = new RuntimeException("root cause");

        CaseAccessException ex = new CaseAccessException("Access denied", cause);

        assertEquals("Access denied", ex.getMessage());
        assertEquals(cause, ex.getCause());
    }

    // -------------------------------------------------------------------------
    // InvalidDluOfficeException
    // -------------------------------------------------------------------------

    @Test
    void invalidDluOfficeException_messageCauseConstructor_setsMessageAndCause() {
        Throwable cause = new RuntimeException("root cause");

        InvalidDluOfficeException ex = new InvalidDluOfficeException("Invalid office", cause);

        assertEquals("Invalid office", ex.getMessage());
        assertEquals(cause, ex.getCause());
    }
}

