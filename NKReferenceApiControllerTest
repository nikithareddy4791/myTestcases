    @Autowired
    private MockMvc mockMvc;

    @MockBean
    private ReferenceDataService referenceDataService;

    private ADA mockAda;
    private Category mockCategory;
    private Tag mockTag;
    private Item mockItem;
    private Status mockStatus;
    private dddOffice mockOffice;
    private ReferenceCode mockRefCode;

    @BeforeEach
    void setUp() {
        mockAda = new ADA();
        mockAda.setId(1);
        mockAda.setFrstNm("Jane");
        mockAda.setLastNm("Doe");
        mockAda.setBoroughNm("Manhattan");

        mockCategory = new Category();
        mockCategory.setId(1);
        mockCategory.setCategoryDesc("Shootings");

        mockTag = new Tag();
        mockTag.setId(1);
        mockTag.setTagDesc("Gun");

        mockItem = new Item();
        mockItem.setId(10);
        mockItem.setItemDesc("ECMS");

        mockStatus = new Status();
        mockStatus.setId(1);
        mockStatus.setStatusDesc("Completed");

        mockOffice = new dddOffice();
        mockOffice.setId(1);
        mockOffice.setDddOfficeDesc("Manhattan");

        mockRefCode = new ReferenceCode();
        mockRefCode.setId(1);
        mockRefCode.setCodeType("STATUS");
        mockRefCode.setCodeVal("OPEN");
        mockRefCode.setCodeDesc("Open Status");
    }

    // =========================================================================
    // GET /reference/adas
    // =========================================================================

    @Test
    @WithMockUser
    void getADAList_returnsOkWithList() throws Exception {
        when(referenceDataService.getAllAdas()).thenReturn(Arrays.asList(mockAda));

        mockMvc.perform(get("/reference/adas")
                .accept(MediaType.APPLICATION_JSON))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$[0].id").value(1))
                .andExpect(jsonPath("$[0].frstNm").value("Jane"))
                .andExpect(jsonPath("$[0].lastNm").value("Doe"));

        verify(referenceDataService, times(1)).getAllAdas();
    }

    @Test
    @WithMockUser
    void getADAList_returnsEmptyList() throws Exception {
        when(referenceDataService.getAllAdas()).thenReturn(Collections.emptyList());

        mockMvc.perform(get("/reference/adas")
                .accept(MediaType.APPLICATION_JSON))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$").isEmpty());
    }

    @Test
    @WithMockUser
    void getADAList_serviceThrowsException_returns500() throws Exception {
        when(referenceDataService.getAllAdas()).thenThrow(new RuntimeException("DB error"));

        mockMvc.perform(get("/reference/adas")
                .accept(MediaType.APPLICATION_JSON))
                .andExpect(status().isInternalServerError());
    }

    @Test
    void getADAList_noAuth_returns401() throws Exception {
        mockMvc.perform(get("/reference/adas")
                .accept(MediaType.APPLICATION_JSON))
                .andExpect(status().isUnauthorized());
    }

    @Test
    @WithMockUser
    void getADAList_noAcceptHeader_returns501() throws Exception {
        mockMvc.perform(get("/reference/adas"))
                .andExpect(status().isNotImplemented());
    }

