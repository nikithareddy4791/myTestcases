    // ----------------------------------------------------------------
    // getdluOffices — supervisor path
    // ----------------------------------------------------------------

    @Test
    void getdluOffices_supervisorUser_returnsAllOffices() {
        dluOffice office = new dluOffice();
        when(authenticationService.isSupervisor()).thenReturn(true);
        when(dluOfficeListRepository.findAllDTO()).thenReturn(List.of(office));

        List<dluOffice> result = referenceDataService.getdluOffices("supervisorUser");

        assertNotNull(result);
        assertEquals(1, result.size());
        verify(dluOfficeListRepository, times(1)).findAllDTO();
        verify(dluOfficeListRepository, never()).findAllDTOForSG(anyString());
    }

    // ----------------------------------------------------------------
    // getdluOffices — non-supervisor path
    // ----------------------------------------------------------------

    @Test
    void getdluOffices_nonSupervisorWithSGAuthority_returnsFilteredOffices() {
        when(authenticationService.isSupervisor()).thenReturn(false);

        GrantedAuthority sgAuthority = new SimpleGrantedAuthority("ROLE_SG-dlu-OFFICE1");
        Authentication auth = mock(Authentication.class);
        when(auth.getAuthorities()).thenReturn((List) List.of(sgAuthority));

        SecurityContext securityContext = mock(SecurityContext.class);
        when(securityContext.getAuthentication()).thenReturn(auth);
        SecurityContextHolder.setContext(securityContext);

        dluOffice office = new dluOffice();
        when(dluOfficeListRepository.findAllDTOForSG("ROLE_SG-dlu-OFFICE1")).thenReturn(List.of(office));

        List<dluOffice> result = referenceDataService.getdluOffices("regularUser");

        assertNotNull(result);
        assertEquals(1, result.size());
        verify(dluOfficeListRepository, times(1)).findAllDTOForSG("ROLE_SG-dlu-OFFICE1");
    }

    @Test
    void getdluOffices_nonSupervisorNoSGAuthority_returnsEmptyList() {
        when(authenticationService.isSupervisor()).thenReturn(false);

        GrantedAuthority otherAuthority = new SimpleGrantedAuthority("ROLE_USER");
        Authentication auth = mock(Authentication.class);
        when(auth.getAuthorities()).thenReturn((List) List.of(otherAuthority));

        SecurityContext securityContext = mock(SecurityContext.class);
        when(securityContext.getAuthentication()).thenReturn(auth);
        SecurityContextHolder.setContext(securityContext);

        List<dluOffice> result = referenceDataService.getdluOffices("regularUser");

        assertNotNull(result);
        assertTrue(result.isEmpty());
        verify(dluOfficeListRepository, never()).findAllDTOForSG(anyString());
    }

