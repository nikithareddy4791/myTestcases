@ExtendWith(MockitoExtension.class)
public class ReferenceDataServiceTest {

    @Mock
    private ADAListRepository adaListRepository;

    @Mock
    private CategoryListRepository categoryListRepository;

    @Mock
    private TagListRepository tagListRepository;

    @Mock
    private ItemListRepository itemListRepository;

    @Mock
    private StatusListRepository statusListRepository;

    @Mock
    private dluOfficeListRepository dluOfficeListRepository;

    @Mock
    private CodeRefRepository codeRefRepository;

    @Mock
    private AuthenticationService authenticationService;

    @Mock
    private ModelMapper modelMapper;

    @InjectMocks
    private ReferenceDataService referenceDataService;

    @BeforeEach
    void setUp() {
        SecurityContextHolder.clearContext();
    }

    // ----------------------------------------------------------------
    // getRefCodeByType
    // ----------------------------------------------------------------

    @Test
    void getRefCodeByType_validCodeType_returnsRefCodes() {
        ReferenceCode code = new ReferenceCode();
        when(codeRefRepository.findDTOByCodeTypeOrderByIdAsc("STATUS")).thenReturn(List.of(code));

        List<ReferenceCode> result = referenceDataService.getRefCodeByType("STATUS");

        assertNotNull(result);
        assertEquals(1, result.size());
        verify(codeRefRepository, times(1)).findDTOByCodeTypeOrderByIdAsc("STATUS");
    }

    @Test
    void getRefCodeByType_noResults_returnsEmptyList() {
        when(codeRefRepository.findDTOByCodeTypeOrderByIdAsc("UNKNOWN")).thenReturn(new ArrayList<>());

        List<ReferenceCode> result = referenceDataService.getRefCodeByType("UNKNOWN");

        assertNotNull(result);
        assertTrue(result.isEmpty());
    }

    @Test
    void getRefCodeByType_repositoryThrows_propagatesException() {
        when(codeRefRepository.findDTOByCodeTypeOrderByIdAsc("STATUS"))
                .thenThrow(new RuntimeException("DB error"));

        assertThrows(RuntimeException.class, () -> referenceDataService.getRefCodeByType("STATUS"));
    }

    // ----------------------------------------------------------------
    // getAllAdas
    // ----------------------------------------------------------------

    @Test
    void getAllAdas_returnsListOfADAs() {
        AdaList adaEntity = new AdaList();
        ADA adaModel = new ADA();
        when(adaListRepository.findAll()).thenReturn(List.of(adaEntity));
        when(modelMapper.map(adaEntity, ADA.class)).thenReturn(adaModel);

        List<ADA> result = referenceDataService.getAllAdas();

        assertNotNull(result);
        assertEquals(1, result.size());
        verify(adaListRepository, times(1)).findAll();
        verify(modelMapper, times(1)).map(adaEntity, ADA.class);
    }

    @Test
    void getAllAdas_emptyRepository_returnsEmptyList() {
        when(adaListRepository.findAll()).thenReturn(new ArrayList<>());

        List<ADA> result = referenceDataService.getAllAdas();

        assertNotNull(result);
        assertTrue(result.isEmpty());
    }

    @Test
    void getAllAdas_multipleEntities_mapsAll() {
        AdaList ada1 = new AdaList();
        AdaList ada2 = new AdaList();
        when(adaListRepository.findAll()).thenReturn(List.of(ada1, ada2));
        when(modelMapper.map(any(AdaList.class), eq(ADA.class))).thenReturn(new ADA());

        List<ADA> result = referenceDataService.getAllAdas();

        assertEquals(2, result.size());
        verify(modelMapper, times(2)).map(any(AdaList.class), eq(ADA.class));
    }

