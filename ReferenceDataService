    public List<DLUOffice> getDLUOffices() {
        if (authenticationService.isSupervisor()) {
            return dluOfficeListRepository.findAllDTO();
        } else {
            List<DLUOffice> results = new ArrayList<>();
            Authentication auth = SecurityContextHolder.getContext().getAuthentication();
            auth.getAuthorities().forEach(authority -> {
                if (authority.getAuthority().startsWith("ROLE_SG-DLU")) {
                    results.addAll(dluOfficeListRepository.findAllDTOForSG(authority.getAuthority()));
                }
            });
            return results;
        }
    }

