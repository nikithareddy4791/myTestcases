    public dddCaseStats getCaseStats() {
        dddCaseStats stats = new dddCaseStats();
        LocalDate today = LocalDate.now();
        LocalDate threeDaysLater = today.plusDays(3);
        if (authenticationService.isSupervisor()) {
            Integer overdue = caseRepository.countByDueDtBeforeAndStatus_IdNot(today, AppConstants.STATUS_COMPLETED);
            stats.setOverdueCount(overdue);
            Integer comingDue = caseRepository.countByDueDtBetweenAndStatus_IdNot(today, threeDaysLater, AppConstants.STATUS_COMPLETED);
            stats.setComingDueCount(comingDue);
        } else {
            Integer overdue = caseRepository.countByDueDtBeforeAndAssignedNmAndStatus_IdNot(today,
                    authenticationService.getUsername(), AppConstants.STATUS_COMPLETED);
            stats.setOverdueCount(overdue);
            Integer comingDue = caseRepository.countByDueDtBetweenAndAssignedNmAndStatus_IdNot(today, threeDaysLater,
                    authenticationService.getUsername(), AppConstants.STATUS_COMPLETED);
            stats.setComingDueCount(comingDue);
        }
        return stats;
    }

    public dddCaseStats getCaseStats(final Collection<Integer> dddOfficeIds) {
        dddCaseStats stats = new dddCaseStats();
        LocalDate today = LocalDate.now(); 
        Integer overdue = caseRepository.countByDueDtBeforeAndddd_IdInAndStatus_IdNot(today, dddOfficeIds, AppConstants.STATUS_COMPLETED);
        stats.setOverdueCount(overdue);
        LocalDate threeDaysLater = today.plusDays(3);
        Integer comingDue = caseRepository.countByDueDtBetweenAndddd_IdInAndStatus_IdNot(today, threeDaysLater, dddOfficeIds, AppConstants.STATUS_COMPLETED);
        stats.setComingDueCount(comingDue);
        return stats;
    }

    @Transactional
    public dddCase createCase(final CreateCaseRequest request) {
        String username = authenticationService.getUsername();
        log.info("createCase for " + username + " " + request.getArrId().trim());
        ArrestInfo arrInfo = null;
        try {
            arrInfo = cdwRepository.getArrestInfo(request.getArrId().trim());
        } catch (Exception e){
            throw new InvalidArrestException("Arrest "+request.getArrId().trim()+" not found");
        }
        log.info(arrInfo.toString());
        if (!authenticationService.hasSealedAccess() && "Y".equals(arrInfo.getArrSealedFlg())) {
            throw new SealedAccessException("User has no sealed access");
        }
        List<dddCase> existingParent = caseRepository.findByArrIdOrderByIdDesc(request.getArrId().trim());
        if (request.getParentId()==null && existingParent != null && existingParent.size() > 0) {
            log.info("Case Exists " + existingParent.get(0).toString());
            dddCase json = new dddCase();
            json.setId(existingParent.get(0).getId());
            Status status = modelMapper.map(existingParent.get(0).getStatus(), Status.class);
            json.setStatus(status);
            return json;
        } else {
            dddOfficeList dddOffice = dddOfficeListRepository.findById(request.getdddOfficeId()).orElse(null);
            if(dddOffice == null){
                throw new InvaliddddOfficeException("ddd Office id " + request.getdddOfficeId() + " not found");
            }
            StatusList notStarted = statusListRepository.findById(AppConstants.STATUS_NOT_STARTED).orElse(null);
            dddCase entityCase = new dddCase();
            entityCase.setArrId(request.getArrId().trim());
            entityCase.setddd(dddOffice);
            entityCase.setStatus(notStarted);
            entityCase.setProactiveFlg((short) request.getProactiveFlg().intValue());
            if (request.getDueDt() != null) {
                entityCase.setDueDt(
                        DateTimeUtils.toDate(request.getDueDt().atStartOfDay(ZoneId.systemDefault()).toInstant()));
            }
            if (request.getRequestDt() != null) {
                entityCase.setRequestDt(
                        DateTimeUtils.toDate(request.getRequestDt().atStartOfDay(ZoneId.systemDefault()).toInstant()));
            } else {
                entityCase.setRequestDt(new Date());
            }
            entityCase.setDvFlg((short) arrInfo.getDvFlg().intValue());
            entityCase.setIndexFlg((short) arrInfo.getIndexCrimeFlg().intValue());
            entityCase.setFelonyFlg((short) arrInfo.getFelonyFlg().intValue());
            caseRepository.save(entityCase);
            log.info("Case Created " + entityCase.getId());
            dddCase dtoCase = new dddCase();
            dtoCase.setId(entityCase.getId());
            dtoCase.setNew(true);
            return dtoCase;
        }
    }

    public dddCase loadCase(final int caseId) {
        Optional<dddCase> entityOpt = caseRepository.findById(caseId);
        if (entityOpt.isEmpty()) {
            throw new CaseNotFoundException("Case not found with id: " + caseId);
        }
        dddCase entity = entityOpt.get();
        //modelMapper.validate();
        dddCase dto = modelMapper.map(entity, dddCase.class);
        if (dto.getStatus() != null && dto.getStatus().getId() != AppConstants.STATUS_NOT_STARTED
                && dto.getStatus().getId() != AppConstants.STATUS_IN_PROGRESS
                && dto.getStatus().getId() != AppConstants.STATUS_WAITING) {
            dto.setActiveFlg(0);
        } else {
            dto.setActiveFlg(1);
        }
        ArrestInfo arrInfo = cdwRepository.getArrestInfo(entity.getArrId());
        // Arrest is sealed
        if ("Y".equals(arrInfo.getArrSealedFlg())) {
            if (!authenticationService.hasSealedAccess()) {
                // User has no sealed access
                throw new SealedAccessException("User has no sealed access");
            } else if (!authenticationService.isSupervisor()
                    && !authenticationService.getUsername().equals(entity.getAssignedNm())) {
                // User has sealed access, but is not supervisor and is not assigned to the case
                if (entity.getddd() == null || !authenticationService.hasRole(entity.getddd().getAdSgNm())) {
                    // ... and User does not belong to the case's ddd office
                    throw new CaseAccessException("User has no access to case");
                }
            }
        }
        dto.setArrest(arrInfo);
        if (entity.getAssignedNm() != null) {
            dto.setAssignedNmInfo(adSearchService.findUser(entity.getAssignedNm()));
        }
        return dto;
    }

    public dddCase saveCase(final dddCase dtoCase) {

        Optional<dddCase> entityOpt = caseRepository.findById(dtoCase.getId());
        if (entityOpt.isEmpty()) {
            throw new CaseNotFoundException("Case not found with id: " + dtoCase.getId());
        }
        dddCase entityCase = entityOpt.get();
        // Optimistic lock: client version must match DB version
        if (dtoCase.getVersion() != null && entityCase.getVersion() != null
                && !entityCase.getVersion().equals(dtoCase.getVersion())) {
            throw new jakarta.persistence.OptimisticLockException(
                    "Case " + dtoCase.getId() + " was modified by another user (expected version " + dtoCase.getVersion()
                            + ", current " + entityCase.getVersion() + ")");
        }
        modelMapper.map(dtoCase, entityCase);

        if (dtoCase.getCategory() != null) {
            CategoryList newCategory = categoryListRepository.findById(dtoCase.getCategory().getId()).orElse(null);
            entityCase.setCategory(newCategory);
        } else if (entityCase.getCategory() != null) {
            entityCase.setCategory(null);
        }

        if (dtoCase.getAda() != null) {
            AdaList newAda = adaListRepository.findById(dtoCase.getAda().getId()).orElse(null);
            entityCase.setAda(newAda);
        } else if (entityCase.getAda() != null) {
            entityCase.setAda(null);
        }

        if (dtoCase.getddd() != null) {
            dddOfficeList newddd = dddOfficeListRepository.findById(dtoCase.getddd().getId()).orElse(null);
            entityCase.setddd(newddd);
        } else if (entityCase.getddd() != null) {
            entityCase.setddd(null);
        }

        if (dtoCase.getStatus() != null) {
            StatusList newStatus = statusListRepository.findById(dtoCase.getStatus().getId()).orElse(null);
            entityCase.setStatus(newStatus);
        } else if (entityCase.getStatus() != null) {
            entityCase.setStatus(null);
        }

        List<CaseTag> updatedTags = new ArrayList<>();
        List<org.nnnn.ddd.model.CaseTag> dtoTags = dtoCase.getTags() != null ? dtoCase.getTags() : List.of();

        for (org.nnnn.ddd.model.CaseTag dtoTag : dtoTags) {
            if (dtoTag.getTagId() == null) continue;
            Optional<CaseTag> foundTag = entityCase.getTags().stream()
                    .filter(entityTag -> entityTag.getTag() != null
                            && dtoTag.getTagId().intValue() == entityTag.getTag().getId())
                    .findFirst();
            if (foundTag.isEmpty()) {
                TagList tag = tagListRepository.findById(dtoTag.getTagId()).orElse(null);
                if (tag != null) {
                    CaseTag newTag = new CaseTag();
                    newTag.setdddCase(entityCase);
                    newTag.setTag(tag);
                    updatedTags.add(newTag);
                } else {
                    log.error("Tag " + dtoTag.getTagId() + " not found for case " + entityCase.getId());
                }
            } else {
                updatedTags.add(foundTag.get());
            }
        }

        entityCase.getTags().clear();
        entityCase.getTags().addAll(updatedTags);

        List<CaseItem> updatedItems = new ArrayList<>();
        List<org.nnnn.ddd.model.CaseItem> dtoItems = dtoCase.getItems() != null ? dtoCase.getItems() : List.of();

        for (org.nnnn.ddd.model.CaseItem dtoItem : dtoItems) {
            Optional<CaseItem> foundItem = Optional.empty();
            if (dtoItem.getId() != null) {
                foundItem = entityCase.getItems().stream()
                        .filter(entityItem -> dtoItem.getId().intValue() == entityItem.getId())
                        .findFirst();
            }
            if (foundItem.isEmpty()) {
                ItemList item = itemListRepository.findById(dtoItem.getItemId()).orElse(null);
                if (item != null) {
                    CaseItem newItem = new CaseItem();
                    newItem.setdddCase(entityCase);
                    newItem.setItem(item);
                    newItem.setNoteDesc(dtoItem.getNoteDesc());
                    newItem.setQuantity(dtoItem.getQuantity());
                    newItem.setStatusDesc(dtoItem.getStatusDesc());
                    updatedItems.add(newItem);
                } else {
                    log.error("Item " + dtoItem.getItemId() + " not found for case " + entityCase.getId());
                }
            } else {
                CaseItem existingItem = foundItem.get();
                existingItem.setNoteDesc(dtoItem.getNoteDesc());
                existingItem.setQuantity(dtoItem.getQuantity());
                existingItem.setStatusDesc(dtoItem.getStatusDesc());
                updatedItems.add(existingItem);
            }
        }

        entityCase.getItems().clear();
        entityCase.getItems().addAll(updatedItems);
        entityCase.setRowUpdtTs(Timestamp.from(Instant.now()));

        caseRepository.saveAndFlush(entityCase);
        dtoCase.setVersion(entityCase.getVersion());
        return dtoCase;
    }

    public CaseListResponse findCases(final CaseFilter filter) {
        CaseListResponse response = new CaseListResponse();
        List<Specification<dddCase>> filters = new ArrayList<>();
        if (filter.getArrId() != null) {
            filters.add(CaseSpecifications.hasArrId(filter.getArrId()));
        }
        if (filter.getRequestDtFrom() != null || filter.getRequestDtTo() != null) {
            filters.add(CaseSpecifications.requestBetween(
                    filter.getRequestDtFrom() != null ? LocalDate.parse(filter.getRequestDtFrom()) : null,
                    filter.getRequestDtTo() != null ? LocalDate.parse(filter.getRequestDtTo()) : null));
        }
        if (filter.getDueDtFrom() != null || filter.getDueDtTo() != null) {
            filters.add(CaseSpecifications.dueBetween(
                    filter.getDueDtFrom() != null ? LocalDate.parse(filter.getDueDtFrom()) : null,
                    filter.getDueDtTo() != null ? LocalDate.parse(filter.getDueDtTo()) : null));
        }
        if (filter.getCategoryIds() != null) {
            filters.add(CaseSpecifications.hasCategories(filter.getCategoryIds()));
        }
        if (filter.getdddOfficeIds() != null && filter.getdddOfficeIds().size() > 0) {
            filters.add(CaseSpecifications.hasdddOfficesIn(filter.getdddOfficeIds()));
        } else if (!authenticationService.isSupervisor()) {
            List<dddOffice> allowedOffices = referenceDataService.getdddOffices(authenticationService.getUsername());
            List<Integer> allowedOfficeIds = allowedOffices.stream()
                    .map(dddOffice::getId) // Map each object to its ID using a method reference
                    .collect(Collectors.toList());
            log.info("looking within " + allowedOfficeIds + " " + allowedOffices + " offices for "+authenticationService.getUsername());
            filters.add(CaseSpecifications.hasdddOfficesIn(allowedOfficeIds).or(CaseSpecifications.hasAssignedNm(authenticationService.getUsername())));
        }
        if (filter.getStatusIds() != null && filter.getStatusIds().size() > 0) {
            filters.add(CaseSpecifications.hasStatusesIn(filter.getStatusIds()));
        }
        if (filter.getTagIds() != null && filter.getTagIds().size() > 0) {
            filters.add(CaseSpecifications.hasTagsIn(filter.getTagIds()));
        }
        if (filter.getAssignedNm() != null) {
            filters.add(CaseSpecifications.hasAssignedNm(filter.getAssignedNm()));
        }
        if (filter.getProactiveFlg()!=null) {
            filters.add(CaseSpecifications.hasProactiveFlg(filter.getProactiveFlg().shortValue()));
        }
        if (filters.isEmpty()) {
            return response;
        }
        filters.add(CaseSpecifications.fetchDependencies());
        
        Sort sort = Sort.by("id").descending();
        if (filter.getSortBy() != null && filter.getSortBy().size() > 0) {
            int i = 0;
            for (String sortBy : filter.getSortBy()) {
                Sort thisSort = Sort.by(sortBy);
                if (filter.getSortOrder() != null && filter.getSortOrder().size() > i) {
                    if (filter.getSortOrder().get(i) == 0) {
                        thisSort = thisSort.ascending();
                    } else {
                        thisSort = thisSort.descending();
                    }
                }
                if (i == 0) {
                    sort = thisSort;
                } else {
                    sort = sort.and(thisSort);
                }
            }
        }

        Pageable pageable = PageRequest.of(filter.getPageNumber() != null ? filter.getPageNumber() : 0,
                filter.getPageSize() != null ? filter.getPageSize() : AppConstants.DEFAULT_PAGE_SIZE,
                sort);

        Page<dddCase> page = caseRepository.findAll(Specification.allOf(filters), pageable);

        List<dddCase> entities = page.getContent();

        List<dddCaseSummary> cases = entities.stream()
                .map(entity -> modelMapper.map(entity, dddCaseSummary.class))
                .toList();
        List<String> arrIds = cases.stream()
                .map(caseSummary -> caseSummary.getArrId())
                .toList();
       
        List<ArrestInfo> arrInfos;

        if (authenticationService.hasSealedAccess()) {
            arrInfos = cdwRepository.getArrestInfoSummary(arrIds);
        } else {
            arrInfos = cdwRepository.getMaskedArrestInfoSummary(arrIds);
        }

        Map<String, ArrestInfo> arrInfoMap = arrInfos.stream()
            .collect(Collectors.toMap(ArrestInfo::getArrId, Function.identity()));

        for(dddCaseSummary caseSummary: cases){
            if(arrInfoMap.get(caseSummary.getArrId().trim())!=null){
                caseSummary.setArrest(arrInfoMap.get(caseSummary.getArrId()));
            }
        } 
        response.setCaseSummaries(cases);
        response.setPageNumber(page.getNumber());
        response.setHasNext(page.hasNext());
        response.setHasPrevious(page.hasPrevious());
        response.setIsFirst(page.isFirst());
        response.setIsLast(page.isLast());
        response.setPageSize(page.getSize());
        response.setTotalElements(page.getTotalElements());
        response.setTotalPages(page.getTotalPages());
        if (authenticationService.isSupervisor() && filter.getdddOfficeIds() != null
                && filter.getdddOfficeIds().size() > 0) {
            response.setCaseStats(getCaseStats(filter.getdddOfficeIds()));
        } else {
            response.setCaseStats(getCaseStats());
        }
        return response;
    }

    @Transactional
    public dddCase saveNote(final Integer caseId, final String noteDesc, final String fileNm,
            final MultipartFile fileContent) {
        dddCase entityCase = caseRepository.findById(caseId).orElse(null);
        
        if (entityCase != null) {
            CaseUpload entityUpload = null;
            if (fileNm != null && fileContent != null) {
                entityUpload = new CaseUpload();
                entityUpload.setdddCase(entityCase);
                entityUpload.setUserNm(authenticationService.getUsername());
                entityUpload.setFileNm(fileNm);
                entityUpload.setDeletedFlg((short) 0);
                caseUploadRepository.saveAndFlush(entityUpload);
                int uploadId = entityUpload.getId();
                String s3Key = getS3Key(caseId, uploadId);
                try {
                    log.info("attempt to upload to S3 "+s3Key);
                    s3Service.uploadMultipartFile(s3Key, fileContent);
                } catch (Exception e) {
                    throw new FileUploadException("Upload to S3 failed");
                }
                entityCase.getUploads().add(entityUpload);
            }
            org.nnnn.ddd.entity.CaseNote entityNote = new org.nnnn.ddd.entity.CaseNote();
            entityNote.setNoteDesc(noteDesc);
            entityNote.setUserNm(authenticationService.getUsername());
            entityNote.setdddCase(entityCase);
            if (entityUpload != null) {
                entityNote.setUpload(entityUpload);
            }
            entityCase.getNotes().add(entityNote);
            caseRepository.save(entityCase); 
            return modelMapper.map(entityCase, dddCase.class);
        } else {
            throw new CaseNotFoundException("Case " + caseId + " not found");
        }
    }

    public Object[] getFile(final int caseId, final int uploadId) {
        CaseUpload caseUploadEntity = caseUploadRepository.findById(uploadId).orElse(null);
        if (caseUploadEntity != null) {
            return new Object[] { caseUploadEntity.getFileNm(), s3Service.downloadFile(getS3Key(caseId, uploadId)) };
        }
        return new Object[] {null, s3Service.downloadFile(getS3Key(caseId, uploadId))};
    }

    public void deleteFile(final int caseId, final int uploadId) {
        CaseUpload caseUploadEntity = caseUploadRepository.findById(uploadId).orElse(null);
        if (caseUploadEntity != null) {
            caseUploadEntity.setDeletedFlg((short) 1);
            caseUploadRepository.save(caseUploadEntity);
        }
        throw new FileDeleteException("Failed to delete file " + uploadId);
    }

    private String getS3Key(final int caseId, final int uploadId)
    {
        return "uploads/case/" + caseId + "/" + uploadId;
    }
}



