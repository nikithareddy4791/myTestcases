CaseServiceControllerTest

@Test
@WithMockUser
void updateCase_optimisticLockException_propagates() throws Exception {
    when(caseService.saveCase(any(dddCase.class)))
            .thenThrow(new jakarta.persistence.OptimisticLockException("Concurrent update"));

    mockMvc.perform(put("/case/100")
            .with(csrf())
            .contentType(MediaType.APPLICATION_JSON)
            .accept(MediaType.APPLICATION_JSON)
            .content(objectMapper.writeValueAsString(mockCaseDto)))
            .andExpect(status().isConflict()); // 409 — per the comment in controller
}

@Test
@WithMockUser
void updateCase_objectOptimisticLockingFailureException_propagates() throws Exception {
    when(caseService.saveCase(any(dddCase.class)))
            .thenThrow(new org.springframework.orm.ObjectOptimisticLockingFailureException(dddCase.class, 100));

    mockMvc.perform(put("/case/100")
            .with(csrf())
            .contentType(MediaType.APPLICATION_JSON)
            .accept(MediaType.APPLICATION_JSON)
            .content(objectMapper.writeValueAsString(mockCaseDto)))
            .andExpect(status().isConflict()); // 409
}


@Test
@WithMockUser
void deleteCaseUploadById_success_returnsOk() throws Exception {
    doNothing().when(caseService).deleteFile(100, 1);

    mockMvc.perform(delete("/case/100/file/1")
            .accept(MediaType.APPLICATION_JSON))
            .andExpect(status().isOk())
            .andExpect(content().string("Success: The operation completed successfully."));

    verify(caseService, times(1)).deleteFile(100, 1);
}

@Test
@WithMockUser
void deleteCaseUploadById_ioException_returns500() throws Exception {
    doNothing().when(caseService).deleteFile(100, 1);
    doThrow(new JsonProcessingException("forced") {})
            .when(objectMapper).readValue(anyString(), eq(String.class));

    mockMvc.perform(delete("/case/100/file/1")
            .accept(MediaType.APPLICATION_JSON))
            .andExpect(status().isInternalServerError());
}

@Test
@WithMockUser
void deleteCaseUploadById_noAcceptHeader_returns501() throws Exception {
    mockMvc.perform(delete("/case/100/file/1"))
            .andExpect(status().isNotImplemented());
}

@Test
void deleteCaseUploadById_noAuth_returns401() throws Exception {
    mockMvc.perform(delete("/case/100/file/1")
            .accept(MediaType.APPLICATION_JSON))
            .andExpect(status().isUnauthorized());
}

