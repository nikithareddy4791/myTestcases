@Test
void handleFileDeleteException_returns500() {
    FileDeleteException ex = new FileDeleteException("Delete failed");
    ResponseEntity<Error> response = handler.handleFileDeleteException(ex);
    assertEquals(HttpStatus.INTERNAL_SERVER_ERROR, response.getStatusCode());
    assertNotNull(response.getBody());
    assertNotNull(response.getBody().getMessage());
    assertNotNull(response.getBody().getCode());
}

@Test
void handleOptimisticLockException_returns409() {
    ObjectOptimisticLockingFailureException ex = 
        new ObjectOptimisticLockingFailureException(dddCase.class, 100);
    ResponseEntity<Error> response = handler.handleOptimisticLock(ex);
    assertEquals(HttpStatus.CONFLICT, response.getStatusCode());
    assertNotNull(response.getBody());
    assertNotNull(response.getBody().getMessage());
    assertNotNull(response.getBody().getCode());
}

@Test
void handleJpaOptimisticLockException_returns409() {
    jakarta.persistence.OptimisticLockException ex = 
        new jakarta.persistence.OptimisticLockException("Concurrent update");
    ResponseEntity<Error> response = handler.handleOptimisticLock(ex);
    assertEquals(HttpStatus.CONFLICT, response.getStatusCode());
    assertNotNull(response.getBody());
}



