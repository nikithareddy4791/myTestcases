package org.nnnn.ddd.exceptions;
import org.nnnn.ddd.AppConstants;
import org.nnnn.ddd.ErrorCode;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.ControllerAdvice;
import org.springframework.web.bind.annotation.ExceptionHandler;
import org.springframework.web.servlet.mvc.method.annotation.ResponseEntityExceptionHandler;
@ControllerAdvice
public class GlobalExceptionHandler extends ResponseEntityExceptionHandler {
    
    @ExceptionHandler(SealedAccessException.class)
    public ResponseEntity<org.nnnn.ddd.model.Error> handleSealedAccessException(SealedAccessException ex) {
        org.nnnn.ddd.model.Error error = new org.nnnn.ddd.model.Error();
        error.setMessage(ErrorCode.SEALED_ACCESS_PERM.getMessage());
        error.setCode(String.valueOf(ErrorCode.SEALED_ACCESS_PERM.getCode()));
        return new ResponseEntity<>(error, HttpStatus.FORBIDDEN);
    }
    @ExceptionHandler(CaseNotFoundException.class)
    public ResponseEntity<org.nnnn.ddd.model.Error> handleCaseNotFoundException(CaseNotFoundException ex) {
        org.nnnn.ddd.model.Error error = new org.nnnn.ddd.model.Error();
        error.setMessage(ErrorCode.CASE_NOT_FOUND.getMessage());
        error.setCode(String.valueOf(ErrorCode.CASE_NOT_FOUND.getCode()));
        return new ResponseEntity<>(error, HttpStatus.INTERNAL_SERVER_ERROR);
    }
    @ExceptionHandler(InvalidArrestException.class)
    public ResponseEntity<org.nnnn.ddd.model.Error> handleInvalidArrestException(InvalidArrestException ex) {
        org.nnnn.ddd.model.Error error = new org.nnnn.ddd.model.Error();
        error.setMessage(ErrorCode.ARR_NOT_FOUND.getMessage());
        error.setCode(String.valueOf(ErrorCode.ARR_NOT_FOUND.getCode()));
        return new ResponseEntity<>(error, HttpStatus.INTERNAL_SERVER_ERROR);
    }
    @ExceptionHandler(FileUploadException.class)
    public ResponseEntity<org.nnnn.ddd.model.Error> handleFileUploadException(FileUploadException ex) {
        org.nnnn.ddd.model.Error error = new org.nnnn.ddd.model.Error();
        error.setMessage(ErrorCode.FILE_UPLOAD_ERR.getMessage());
        error.setCode(String.valueOf(ErrorCode.FILE_UPLOAD_ERR.getCode()));
        return new ResponseEntity<>(error, HttpStatus.INTERNAL_SERVER_ERROR);
    }
}


