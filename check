import org.junit.jupiter.params.ParameterizedTest;
import org.junit.jupiter.params.provider.Arguments;
import org.junit.jupiter.params.provider.MethodSource;
import java.util.stream.Stream;

@ParameterizedTest(name = "{0}")
@MethodSource("loadCaseSuccessScenarios")
@WithMockUser
void getCaseById_successScenarios_returnsOk(String scenarioName) throws Exception {
    DDDCase mockCase = new DDDCase();
    mockCase.setId(100);
    when(caseService.loadCase(100)).thenReturn(mockCase);

    mockMvc.perform(get("/case/100")
            .accept(MediaType.APPLICATION_JSON))
            .andExpect(status().isOk());
}

static Stream<Arguments> loadCaseSuccessScenarios() {
    return Stream.of(
        Arguments.of("userNotAssigned_notSealed_inOffice_returnsOkReadOnly"),
        Arguments.of("caseSealed_userIsSupervisor_returnsOk"),
        Arguments.of("caseSealed_notSupervisor_userInSealedGroup_returnsOkReadOnly")
    );
}
