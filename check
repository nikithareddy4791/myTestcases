package org.nnnn.ddd.api;

import com.fasterxml.jackson.databind.ObjectMapper;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.mockito.junit.jupiter.MockitoSettings;
import org.mockito.quality.Strictness;
import org.nnnn.ddd.exceptions.CaseAccessException;
import org.nnnn.ddd.exceptions.CaseNotFoundException;
import org.nnnn.ddd.exceptions.FileDeleteException;
import org.nnnn.ddd.exceptions.InvalidArrestException;
import org.nnnn.ddd.exceptions.SealedAccessException;
import org.nnnn.ddd.model.*;
import org.nnnn.ddd.service.AuthenticationService;
import org.nnnn.ddd.service.CaseService;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;

import jakarta.servlet.http.HttpServletRequest;
import java.util.List;

import static org.assertj.core.api.Assertions.*;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

/**
 * Direct unit tests for CaseApiController — bypasses MockMvc/Spring entirely.
 * Calls controller methods directly to guarantee JaCoCo line coverage on:
 * Line 149 (getCaseById SealedAccess rethrow)
 * Line 165 (getCaseById generic exception → 500)
 * Line 179 (getCaseIntakeList success → 200)
 * Line 193 (deleteCaseUploadById → deleteFile called)
 * Lines 227-231 (getCaseStats full method)
 */
@ExtendWith(MockitoExtension.class)
@MockitoSettings(strictness = Strictness.LENIENT)
@DisplayName("CaseApiController Direct Unit Tests")
public class CaseApiControllerDirectTest {

    @Mock
    private CaseService caseService;

    @Mock
    private AuthenticationService authenticationService;

    @Mock
    private HttpServletRequest request;

    @Mock
    private ObjectMapper objectMapper;

    @InjectMocks
    private CaseApiController controller;

    @BeforeEach
    void setUp() {
        // Make every request appear to accept application/json
        when(request.getHeader("Accept")).thenReturn("application/json");
    }

    // =========================================================================
    // getCaseById() — lines 149 (SealedAccess rethrow), 165 (generic → 500)
    // =========================================================================

    @Test
    @DisplayName("getCaseById - SealedAccessException is rethrown (line 149)")
    void getCaseById_sealedAccessException_isRethrown() {
        when(caseService.loadCase(100))
                .thenThrow(new SealedAccessException("no sealed access"));

        assertThatThrownBy(() -> controller.getCaseById(100))
                .isInstanceOf(SealedAccessException.class)
                .hasMessageContaining("no sealed access");
    }

    @Test
    @DisplayName("getCaseById - CaseAccessException is rethrown (line 157)")
    void getCaseById_caseAccessException_isRethrown() {
        when(caseService.loadCase(100))
                .thenThrow(new CaseAccessException("no access"));

        assertThatThrownBy(() -> controller.getCaseById(100))
                .isInstanceOf(CaseAccessException.class);
    }

    @Test
    @DisplayName("getCaseById - CaseNotFoundException is rethrown (line 158)")
    void getCaseById_caseNotFoundException_isRethrown() {
        when(caseService.loadCase(100))
                .thenThrow(new CaseNotFoundException("not found"));

        assertThatThrownBy(() -> controller.getCaseById(100))
                .isInstanceOf(CaseNotFoundException.class);
    }

    @Test
    @DisplayName("getCaseById - generic exception returns 500 (line 165)")
    void getCaseById_genericException_returns500() {
        when(caseService.loadCase(100))
                .thenThrow(new RuntimeException("unexpected"));

        ResponseEntity<DDDCase> response = controller.getCaseById(100);

        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.INTERNAL_SERVER_ERROR);
    }

    @Test
    @DisplayName("getCaseById - success returns 200")
    void getCaseById_success_returns200() {
        DDDCase dto = new DDDCase();
        dto.setId(100);
        when(caseService.loadCase(100)).thenReturn(dto);

        ResponseEntity<DDDCase> response = controller.getCaseById(100);

        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
        assertThat(response.getBody().getId()).isEqualTo(100);
    }

    @Test
    @DisplayName("getCaseById - no Accept header returns 501")
    void getCaseById_noAcceptHeader_returns501() {
        when(request.getHeader("Accept")).thenReturn(null);

        ResponseEntity<DDDCase> response = controller.getCaseById(100);

        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.NOT_IMPLEMENTED);
        verify(caseService, never()).loadCase(anyInt());
    }

    // =========================================================================
    // getCaseIntakeList() — line 179
    // =========================================================================

    @Test
    @DisplayName("getCaseIntakeList - success returns 200 (line 179)")
    void getCaseIntakeList_success_returns200() {
        IntakeListResponse response = new IntakeListResponse();
        response.setIntakeArrests(List.of(new ArrestInfo()));
        when(caseService.getIntakeArrests(any())).thenReturn(response);

        IntakeFilter filter = new IntakeFilter();
        filter.setArrDtFrom("2024-01-01");
        filter.setArrDtTo("2024-12-31");

        ResponseEntity<IntakeListResponse> result = controller.getCaseIntakeList(filter);

        assertThat(result.getStatusCode()).isEqualTo(HttpStatus.OK);
        assertThat(result.getBody().getIntakeArrests()).hasSize(1);
        verify(caseService).getIntakeArrests(filter);
    }

    @Test
    @DisplayName("getCaseIntakeList - exception returns 500")
    void getCaseIntakeList_exception_returns500() {
        when(caseService.getIntakeArrests(any()))
                .thenThrow(new RuntimeException("CDW error"));

        IntakeFilter filter = new IntakeFilter();
        filter.setArrDtFrom("2024-01-01");
        filter.setArrDtTo("2024-12-31");

        ResponseEntity<IntakeListResponse> result = controller.getCaseIntakeList(filter);

        assertThat(result.getStatusCode()).isEqualTo(HttpStatus.INTERNAL_SERVER_ERROR);
    }

    @Test
    @DisplayName("getCaseIntakeList - no Accept header returns 501")
    void getCaseIntakeList_noAcceptHeader_returns501() {
        when(request.getHeader("Accept")).thenReturn(null);

        IntakeFilter filter = new IntakeFilter();
        ResponseEntity<IntakeListResponse> result = controller.getCaseIntakeList(filter);

        assertThat(result.getStatusCode()).isEqualTo(HttpStatus.NOT_IMPLEMENTED);
        verify(caseService, never()).getIntakeArrests(any());
    }

    // =========================================================================
    // deleteCaseUploadById() — line 193
    // =========================================================================

    @Test
    @DisplayName("deleteCaseUploadById - deleteFile called (line 193)")
    void deleteCaseUploadById_deleteFileCalled() {
        doThrow(new FileDeleteException("Failed to delete file 1"))
                .when(caseService).deleteFile(100, 1);

        // FileDeleteException is RuntimeException — propagates out of controller
        // (controller only catches IOException)
        assertThatThrownBy(() -> controller.deleteCaseUploadById(100, 1))
                .isInstanceOf(FileDeleteException.class);

        verify(caseService).deleteFile(100, 1);
    }

    @Test
    @DisplayName("deleteCaseUploadById - no Accept header returns 501")
    void deleteCaseUploadById_noAcceptHeader_returns501() throws Exception {
        when(request.getHeader("Accept")).thenReturn(null);

        ResponseEntity<String> result = controller.deleteCaseUploadById(100, 1);

        assertThat(result.getStatusCode()).isEqualTo(HttpStatus.NOT_IMPLEMENTED);
        verify(caseService, never()).deleteFile(anyInt(), anyInt());
    }

    // =========================================================================
    // getCaseStats() — lines 227-231
    // =========================================================================

    @Test
    @DisplayName("getCaseStats - success returns 200 (lines 227-231)")
    void getCaseStats_success_returns200() {
        DDDCaseStats stats = new DDDCaseStats();
        stats.setOverdueCount(3);
        stats.setComingDueCount(2);

        when(authenticationService.getUsername()).thenReturn("jdoe");
        when(caseService.getCaseStats("jdoe")).thenReturn(stats);

        ResponseEntity<DDDCaseStats> result = controller.getCaseStats();

        assertThat(result.getStatusCode()).isEqualTo(HttpStatus.OK);
        assertThat(result.getBody().getOverdueCount()).isEqualTo(3);
        assertThat(result.getBody().getComingDueCount()).isEqualTo(2);
        verify(caseService).getCaseStats("jdoe");
    }

    @Test
    @DisplayName("getCaseStats - exception returns 500")
    void getCaseStats_exception_returns500() {
        when(authenticationService.getUsername()).thenReturn("jdoe");
        when(caseService.getCaseStats("jdoe"))
                .thenThrow(new RuntimeException("stats error"));

        ResponseEntity<DDDCaseStats> result = controller.getCaseStats();

        assertThat(result.getStatusCode()).isEqualTo(HttpStatus.INTERNAL_SERVER_ERROR);
    }

    @Test
    @DisplayName("getCaseStats - no Accept header returns 501")
    void getCaseStats_noAcceptHeader_returns501() {
        when(request.getHeader("Accept")).thenReturn(null);

        ResponseEntity<DDDCaseStats> result = controller.getCaseStats();

        assertThat(result.getStatusCode()).isEqualTo(HttpStatus.NOT_IMPLEMENTED);
        verify(caseService, never()).getCaseStats(anyString());
    }

    // =========================================================================
    // createCaseByArrest() — lines 116, 117, 118
    // =========================================================================

    @Test
    @DisplayName("createCaseByArrest - new case returns 201 (line 116)")
    void createCase_newCase_returns201() {
        DDDCase result = new DDDCase();
        result.setId(1);
        result.setNew(true);
        when(caseService.createCase(any())).thenReturn(result);

        CreateCaseRequest req = new CreateCaseRequest();
        req.setArrId("ARR001");
        req.setDddOfficeId(1);
        req.setProactiveFlg(0);

        ResponseEntity<DDDCase> response = controller.createCaseByArrest(req);

        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.CREATED);
    }

    @Test
    @DisplayName("createCaseByArrest - existing case returns 200 (line 117)")
    void createCase_existingCase_returns200() {
        DDDCase result = new DDDCase();
        result.setId(1);
        result.setNew(false);
        when(caseService.createCase(any())).thenReturn(result);

        CreateCaseRequest req = new CreateCaseRequest();
        req.setArrId("ARR001");
        req.setDddOfficeId(1);
        req.setProactiveFlg(0);

        ResponseEntity<DDDCase> response = controller.createCaseByArrest(req);

        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
    }

    @Test
    @DisplayName("createCaseByArrest - SealedAccessException rethrown (line 118)")
    void createCase_sealedAccessException_isRethrown() {
        when(caseService.createCase(any()))
                .thenThrow(new SealedAccessException("no sealed access"));

        CreateCaseRequest req = new CreateCaseRequest();
        req.setArrId("ARR001");
        req.setDddOfficeId(1);
        req.setProactiveFlg(0);

        assertThatThrownBy(() -> controller.createCaseByArrest(req))
                .isInstanceOf(SealedAccessException.class);
    }

    @Test
    @DisplayName("createCaseByArrest - InvalidArrestException rethrown (line 118)")
    void createCase_invalidArrestException_isRethrown() {
        when(caseService.createCase(any()))
                .thenThrow(new InvalidArrestException("not found"));

        CreateCaseRequest req = new CreateCaseRequest();
        req.setArrId("ARR001");
        req.setDddOfficeId(1);
        req.setProactiveFlg(0);

        assertThatThrownBy(() -> controller.createCaseByArrest(req))
                .isInstanceOf(InvalidArrestException.class);
    }

    @Test
    @DisplayName("createCaseByArrest - generic exception returns 500")
    void createCase_genericException_returns500() {
        when(caseService.createCase(any()))
                .thenThrow(new RuntimeException("unexpected"));

        CreateCaseRequest req = new CreateCaseRequest();
        req.setArrId("ARR001");
        req.setDddOfficeId(1);
        req.setProactiveFlg(0);

        ResponseEntity<DDDCase> response = controller.createCaseByArrest(req);

        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.INTERNAL_SERVER_ERROR);
    }
}
