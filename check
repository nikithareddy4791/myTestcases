@ExtendWith(MockitoExtension.class)
@MockitoSettings(strictness = Strictness.LENIENT)
@DisplayName("EmailService Tests")
public class EmailServiceTest {

    @Mock private CaseRepository caseRepository;
    @Mock private ADSearchService adSearchService;
    @Mock private JavaMailSenderImpl mailSender;
    @Mock private Environment env;

    @InjectMocks
    private EmailService emailService;

    private User regularUser;
    private User testUser;
    private DddCase overdueCase;
    private DddCase comingDueCase;
    private StatusList statusInProgress;

    // Real CC address from production sendMail()
    private static final String REAL_CC = "IBMNNNN-DDD@wwpdl.vnet.ibm.com";
    private static final String FROM    = "DDD-Notification@nnnn.org";

    @BeforeEach
    void setUp() {
        statusInProgress = new StatusList();
        statusInProgress.setId(AppConstants.STATUS_IN_PROGRESS);
        statusInProgress.setStatusDesc("In Progress");

        regularUser = new User();
        regularUser.setUsername("jdoe");
        regularUser.setFirstName("John");
        regularUser.setLastName("Doe");
        regularUser.setEmail("jdoe@nnnn.org");
        regularUser.setRank("Detective");

        testUser = new User();
        testUser.setUsername("T-SG-testuser");
        testUser.setEmail("testuser@nnnn.org");
        testUser.setRank("Sgt");
        testUser.setLastName("ddd-testuser");

        overdueCase = new DddCase();
        overdueCase.setId(100);
        overdueCase.setArrId("ARR001");
        overdueCase.setAssignedNm("jdoe");
        overdueCase.setStatus(statusInProgress);
        overdueCase.setRequestDt(java.sql.Date.valueOf(LocalDate.now().minusDays(30)));
        overdueCase.setDueDt(java.sql.Date.valueOf(LocalDate.now().minusDays(1)));

        comingDueCase = new DddCase();
        comingDueCase.setId(101);
        comingDueCase.setArrId("ARR002");
        comingDueCase.setAssignedNm("jdoe");
        comingDueCase.setStatus(statusInProgress);
        comingDueCase.setRequestDt(java.sql.Date.valueOf(LocalDate.now().minusDays(10)));
        comingDueCase.setDueDt(java.sql.Date.valueOf(LocalDate.now().plusDays(2)));

        lenient().when(env.acceptsProfiles(Profiles.of("prod"))).thenReturn(false);
        lenient().when(env.getActiveProfiles()).thenReturn(new String[]{"dev"});

        jakarta.mail.Session mockSession = mock(jakarta.mail.Session.class);
        lenient().when(mailSender.getSession()).thenReturn(mockSession);
    }

    // =========================================================================
    // runScheduledTask()
    // =========================================================================

    @Test
    @DisplayName("runScheduledTask - delegates to sendOverdueEmail")
    void runScheduledTask_delegatesToSendOverdueEmail() {
        when(caseRepository.findByDueDtBeforeAndStatus_IdNotAndAssignedNmNotNull(any(), anyInt()))
                .thenReturn(Collections.emptyList());
        when(caseRepository.findByDueDtBetweenAndStatus_IdNotAndAssignedNmNotNull(any(), any(), anyInt()))
                .thenReturn(Collections.emptyList());

        emailService.runScheduledTask();

        verify(caseRepository).findByDueDtBeforeAndStatus_IdNotAndAssignedNmNotNull(any(), anyInt());
    }

    // =========================================================================
    // sendOverdueEmail() — no cases
    // =========================================================================

    @Test
    @DisplayName("sendOverdueEmail - does nothing when no overdue or coming due cases")
    void sendOverdueEmail_noCases_doesNotSendEmail() {
        when(caseRepository.findByDueDtBeforeAndStatus_IdNotAndAssignedNmNotNull(any(), anyInt()))
                .thenReturn(Collections.emptyList());
        when(caseRepository.findByDueDtBetweenAndStatus_IdNotAndAssignedNmNotNull(any(), any(), anyInt()))
                .thenReturn(Collections.emptyList());

        emailService.sendOverdueEmail();

        verify(mailSender, never()).send(any(SimpleMailMessage.class));
        verifyNoInteractions(adSearchService);
    }

    // =========================================================================
    // sendMail() — from address
    // Production: message.setFrom("DDD-Notification@nnnn.org")
    // =========================================================================

    @Test
    @DisplayName("sendMail - from address is DDD-Notification@nnnn.org")
    void sendMail_fromAddressIsCorrect() {
        when(caseRepository.findByDueDtBeforeAndStatus_IdNotAndAssignedNmNotNull(any(), anyInt()))
                .thenReturn(List.of(overdueCase));
        when(caseRepository.findByDueDtBetweenAndStatus_IdNotAndAssignedNmNotNull(any(), any(), anyInt()))
                .thenReturn(Collections.emptyList());
        when(adSearchService.findUser("jdoe")).thenReturn(regularUser);

        emailService.sendOverdueEmail();

        ArgumentCaptor<SimpleMailMessage> captor = ArgumentCaptor.forClass(SimpleMailMessage.class);
        verify(mailSender).send(captor.capture());
        assertThat(captor.getValue().getFrom()).isEqualTo(FROM);
    }

    // =========================================================================
    // sendMail() — to address
    // Production: message.setTo(user.getEmail()) — always the user's email
    // There is NO special routing for T-SG or V- users in production code
    // =========================================================================

    @Test
    @DisplayName("sendMail - to address is user email for regular user")
    void sendMail_toAddressIsUserEmail_regularUser() {
        when(caseRepository.findByDueDtBeforeAndStatus_IdNotAndAssignedNmNotNull(any(), anyInt()))
                .thenReturn(List.of(overdueCase));
        when(caseRepository.findByDueDtBetweenAndStatus_IdNotAndAssignedNmNotNull(any(), any(), anyInt()))
                .thenReturn(Collections.emptyList());
        when(adSearchService.findUser("jdoe")).thenReturn(regularUser);

        emailService.sendOverdueEmail();

        ArgumentCaptor<SimpleMailMessage> captor = ArgumentCaptor.forClass(SimpleMailMessage.class);
        verify(mailSender).send(captor.capture());
        assertThat(captor.getValue().getTo()).contains("jdoe@nnnn.org");
    }

    @Test
    @DisplayName("sendMail - to address is T-SG user email (no special routing in production)")
    void sendMail_toAddressIsUserEmail_testUserTSG() {
        overdueCase.setAssignedNm("T-SG-testuser");

        when(caseRepository.findByDueDtBeforeAndStatus_IdNotAndAssignedNmNotNull(any(), anyInt()))
                .thenReturn(List.of(overdueCase));
        when(caseRepository.findByDueDtBetweenAndStatus_IdNotAndAssignedNmNotNull(any(), any(), anyInt()))
                .thenReturn(Collections.emptyList());
        when(adSearchService.findUser("T-SG-testuser")).thenReturn(testUser);

        emailService.sendOverdueEmail();

        ArgumentCaptor<SimpleMailMessage> captor = ArgumentCaptor.forClass(SimpleMailMessage.class);
        verify(mailSender).send(captor.capture());
        // Production always sends to user.getEmail() — no special T-SG routing
        assertThat(captor.getValue().getTo()).contains("testuser@nnnn.org");
    }

    @Test
    @DisplayName("sendMail - to address is V- user email (no special routing in production)")
    void sendMail_toAddressIsUserEmail_testUserV() {
        User vUser = new User();
        vUser.setUsername("V-vuser");
        vUser.setEmail("vuser@nnnn.org");
        vUser.setRank("Sgt");
        vUser.setLastName("vuser");
