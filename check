@Test
    void saveItemList_returnsOkWithUpdatedList_whenAcceptIsJson() throws Exception {
        Item item = new Item(1, "ECMS", 0);
        List<Item> input = List.of(item);
        List<Item> saved = List.of(item);

        when(request.getHeader("Accept")).thenReturn("application/json");
        when(referenceDataService.updateItems(input)).thenReturn(saved);

        ResponseEntity<List<Item>> response = controller.saveItemList(input);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals(saved, response.getBody());
        verify(referenceDataService).updateItems(input);
    }

    @Test
    void saveItemList_returnsInternalServerError_whenServiceThrows() throws Exception {
        List<Item> input = List.of(new Item(1, "ECMS", 0));

        when(request.getHeader("Accept")).thenReturn("application/json");
        when(referenceDataService.updateItems(input)).thenThrow(new RuntimeException("DB error"));

        ResponseEntity<List<Item>> response = controller.saveItemList(input);

        assertEquals(HttpStatus.INTERNAL_SERVER_ERROR, response.getStatusCode());
    }

    @Test
    void saveItemList_returnsNotImplemented_whenAcceptHeaderMissing() {
        when(request.getHeader("Accept")).thenReturn(null);

        ResponseEntity<List<Item>> response = controller.saveItemList(List.of(new Item(1, "ECMS", 0)));

        assertEquals(HttpStatus.NOT_IMPLEMENTED, response.getStatusCode());
        verifyNoInteractions(referenceDataService);
    }

    @Test
    void saveItemList_returnsNotImplemented_whenAcceptIsNotJson() {
        when(request.getHeader("Accept")).thenReturn("text/xml");

        ResponseEntity<List<Item>> response = controller.saveItemList(List.of(new Item(1, "ECMS", 0)));

        assertEquals(HttpStatus.NOT_IMPLEMENTED, response.getStatusCode());
        verifyNoInteractions(referenceDataService);
    }
