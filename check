    // ----------------------------------------------------------------
    // getdddOffices — supervisor path
    // ----------------------------------------------------------------

    @Test
    void getdddOffices_supervisorUser_returnsAllOffices() {
        dddOffice office = new dddOffice();
        when(authenticationService.isSupervisor()).thenReturn(true);
        when(dddOfficeListRepository.findAllDTO()).thenReturn(List.of(office));

        List<dddOffice> result = referenceDataService.getdddOffices("supervisorUser");

        assertNotNull(result);
        assertEquals(1, result.size());
        verify(dddOfficeListRepository, times(1)).findAllDTO();
        verify(dddOfficeListRepository, never()).findAllDTOForSG(anyString());
    }

    @Test
    void getdddOffices_nonSupervisorNoSGAuthority_returnsEmptyList() {
        when(authenticationService.isSupervisor()).thenReturn(false);

        GrantedAuthority otherAuthority = new SimpleGrantedAuthority("ROLE_USER");
        Authentication auth = mock(Authentication.class);
        when(auth.getAuthorities()).thenReturn((List) List.of(otherAuthority));

        SecurityContext securityContext = mock(SecurityContext.class);
        when(securityContext.getAuthentication()).thenReturn(auth);
        SecurityContextHolder.setContext(securityContext);

        List<dddOffice> result = referenceDataService.getdddOffices("regularUser");

        assertNotNull(result);
        assertTrue(result.isEmpty());
        verify(dddOfficeListRepository, never()).findAllDTOForSG(anyString());
    }

