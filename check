    // =========================================================================
    // Helper — builds raw result list the same way JPA native query returns it
    // =========================================================================

    /**
     * Wraps Object[] rows into a raw List that simulates JPA getResultList().
     * JPA returns List<Object[]> — but the generic type is erased at runtime.
     * Using raw List avoids the ClassCastException when Mockito returns it.
     */
    @SuppressWarnings({"unchecked", "rawtypes"})
    private List buildRawResultList(Object[]... rows) {
        List list = new ArrayList();
        for (Object[] row : rows) {
            list.add(row);
        }
        return list;
    }

    private Object[] buildRow(String arrId, String topCharge, Date arrDt,
                               String frstNm, String lastNm,
                               String nysid, Character sealedFlg) {
        return new Object[]{arrId, topCharge, arrDt, frstNm, lastNm, nysid, sealedFlg};
    }

