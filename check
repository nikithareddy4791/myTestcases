  @Transactional
    public DDDCase createCase(final CreateCaseRequest request) {
        String username = authenticationService.getUsername();
        log.info("createCase for " + username + " " + request.getArrId().trim());
        ArrestInfo arrInfo = null;
        try {
            arrInfo = cdwRepository.getArrestInfo(request.getArrId().trim());
        } catch (Exception e){
            throw new InvalidArrestException("Arrest "+request.getArrId().trim()+" not found");
        }
        log.info(arrInfo.toString());
        if (!authenticationService.hasSealedAccess() && "Y".equals(arrInfo.getArrSealedFlg())) {
            throw new SealedAccessException("User has no sealed access");
        }
        List<DddCase> existingParent = caseRepository.findByArrIdOrderByIdDesc(request.getArrId().trim());
        if (request.getParentId()==null && existingParent != null && existingParent.size() > 0) {
            log.info("Case Exists " + existingParent.get(0).toString());
            DDDCase json = new DDDCase();
            json.setId(existingParent.get(0).getId());
            Status status = modelMapper.map(existingParent.get(0).getStatus(), Status.class);
            json.setStatus(status);
            return json;
        } else {
            DddOfficeList dddOffice = dddOfficeListRepository.findById(request.getDddOfficeId()).orElse(null);
            if(dddOffice == null){
                throw new InvalidDDDOfficeException(ErrorCode.DDD_OFFICE_NOT_FOUND.getMessage());
            }
            CategoryList category = categoryListRepository.findById(request.getCategoryId()).orElse(null);
            if(category == null){
                throw new InvalidCategoryException(ErrorCode.CATEGORY_NOT_FOUND.getMessage());
            }
            StatusList notStarted = statusListRepository.findById(AppConstants.STATUS_NOT_STARTED).orElse(null);
            DddCase entityCase = new DddCase();
            entityCase.setArrId(request.getArrId().trim());
            entityCase.setDdd(dddOffice);
            entityCase.setCategory(category);
            entityCase.setStatus(notStarted);
            entityCase.setProactiveFlg((short) request.getProactiveFlg().intValue());
            if (request.getDueDt() != null) {
                entityCase.setDueDt(
                        DateTimeUtils.toDate(request.getDueDt().atStartOfDay(ZoneId.systemDefault()).toInstant()));
            }
            if (request.getRequestDt() != null) {
                entityCase.setRequestDt(
                        DateTimeUtils.toDate(request.getRequestDt().atStartOfDay(ZoneId.systemDefault()).toInstant()));
            } else {
                entityCase.setRequestDt(new Date());
            }
            entityCase.setDvFlg((short) arrInfo.getDvFlg().intValue());
            entityCase.setIndexFlg((short) arrInfo.getIndexCrimeFlg().intValue());
            entityCase.setFelonyFlg((short) arrInfo.getFelonyFlg().intValue());
            caseRepository.save(entityCase);
            log.info("Case Created " + entityCase.getId());
            DDDCase dtoCase = new DDDCase();
            dtoCase.setId(entityCase.getId());
            dtoCase.setNew(true);
            return dtoCase;
        }
    }
