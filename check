@Test
void saveItemList_returnsOkWithUpdatedList_whenAcceptIsJson() throws Exception {
    System.out.println("referenceDataService is: " + referenceDataService);
    System.out.println("controller is: " + controller);

    Item item = new Item(1, "ECMS", 0);
    List<Item> saved = List.of(item);

    when(request.getHeader("Accept")).thenReturn("application/json");
    when(referenceDataService.updateItems(any())).thenReturn(saved);

    ResponseEntity<List<Item>> response = controller.saveItemList(List.of(item));

    System.out.println("Response status: " + response.getStatusCode());

    assertEquals(HttpStatus.OK, response.getStatusCode());
}
