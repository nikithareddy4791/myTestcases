@Test
@WithMockUser
void getUserByName_objectMapperThrows_returns500() throws Exception {
    doThrow(new JsonProcessingException("forced") {})
            .when(objectMapper).readValue(anyString(), eq(User.class));

    mockMvc.perform(get("/user/testuser")
            .accept(MediaType.APPLICATION_JSON))
            .andExpect(status().isInternalServerError());
}

@Test
@WithMockUser
void loginUser_objectMapperThrows_returns500() throws Exception {
    doThrow(new JsonProcessingException("forced") {})
            .when(objectMapper).readValue(anyString(), eq(String.class));

    mockMvc.perform(get("/user/login")
            .param("username", "testuser")
            .accept(MediaType.APPLICATION_JSON))
            .andExpect(status().isInternalServerError());
}

@SpyBean
private ObjectMapper objectMapper;
