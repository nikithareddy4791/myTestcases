package org.nnnn.ddd.service;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.ArgumentCaptor;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.mockito.junit.jupiter.MockitoSettings;
import org.mockito.quality.Strictness;
import org.nnnn.ddd.AppConstants;
import org.nnnn.ddd.entity.AdaList;
import org.nnnn.ddd.entity.DddCase;
import org.nnnn.ddd.entity.StatusList;
import org.nnnn.ddd.model.User;
import org.nnnn.ddd.repository.CaseRepository;
import org.springframework.core.env.Environment;
import org.springframework.core.env.Profiles;
import org.springframework.mail.SimpleMailMessage;
import org.springframework.mail.javamail.JavaMailSenderImpl;

import java.time.LocalDate;
import java.util.Arrays;
import java.util.Collections;
import java.util.List;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.anyInt;
import static org.mockito.Mockito.*;

/**
 * Complete EmailService test coverage.
 *
 * Strategy:
 *   - sendOverdueEmail() and runScheduledTask() covered via integration-style
 *     tests that stub the repository and verify mail is sent end-to-end.
 *   - sendMail(), generateEmailBody(), appendCaseInfo() called DIRECTLY
 *     so JaCoCo instruments each line without relying on call-chain attribution.
 *
 * Lines specifically targeted:
 *   Line 45   — sendOverdueEmail() inside runScheduledTask()
 *   Line 89   — sendMail() non-prod else branch
 *   Line 105  — generateEmailBody() singular overdue "1 overdue case:"
 *   Line 117  — generateEmailBody() singular coming due "1 case coming due:"
 *   Lines 133/134 — appendCaseInfo() ADA block
 */
@ExtendWith(MockitoExtension.class)
@MockitoSettings(strictness = Strictness.LENIENT)
@DisplayName("EmailService Tests")
public class EmailServiceTest {

    @Mock private CaseRepository     caseRepository;
    @Mock private ADSearchService    adSearchService;
    @Mock private JavaMailSenderImpl mailSender;
    @Mock private Environment        env;

    @InjectMocks
    private EmailService emailService;

    private User       regularUser;
    private User       testUserTSG;
    private StatusList statusInProgress;

    private static final String REAL_CC = "IBMNNNN-DDD@wwpdl.vnet.ibm.com";
    private static final String FROM    = "DDD-Notification@nnnn.org";

    @BeforeEach
    void setUp() {
        statusInProgress = new StatusList();
        statusInProgress.setId(AppConstants.STATUS_IN_PROGRESS);
        statusInProgress.setStatusDesc("In Progress");

        regularUser = new User();
        regularUser.setUsername("jdoe");
        regularUser.setFirstName("John");
        regularUser.setLastName("Doe");
        regularUser.setEmail("jdoe@nnnn.org");
        regularUser.setRank("Detective");

        testUserTSG = new User();
        testUserTSG.setUsername("T-SG-testuser");
        testUserTSG.setEmail("testuser@nnnn.org");
        testUserTSG.setRank("Sgt");
        testUserTSG.setLastName("Testuser");

        lenient().when(env.acceptsProfiles(Profiles.of("prod"))).thenReturn(false);
        lenient().when(env.getActiveProfiles()).thenReturn(new String[]{"dev"});

        jakarta.mail.Session mockSession = mock(jakarta.mail.Session.class);
        lenient().when(mailSender.getSession()).thenReturn(mockSession);
    }

    // -------------------------------------------------------------------------
    // Helpers
    // -------------------------------------------------------------------------

    private DddCase buildOverdueCase(int id, String arrId, String assignedNm) {
        DddCase c = new DddCase();
        c.setId(id);
        c.setArrId(arrId);
        c.setAssignedNm(assignedNm);
        c.setStatus(statusInProgress);
        c.setRequestDt(java.sql.Date.valueOf(LocalDate.now().minusDays(30)));
        c.setDueDt(java.sql.Date.valueOf(LocalDate.now().minusDays(1)));
        return c;
    }

    private DddCase buildComingDueCase(int id, String arrId, String assignedNm) {
        DddCase c = new DddCase();
        c.setId(id);
        c.setArrId(arrId);
        c.setAssignedNm(assignedNm);
        c.setStatus(statusInProgress);
        c.setRequestDt(java.sql.Date.valueOf(LocalDate.now().minusDays(10)));
        c.setDueDt(java.sql.Date.valueOf(LocalDate.now().plusDays(2)));
        return c;
    }

    private void stubRepoOverdueOnly(List<DddCase> overdue) {
        when(caseRepository.findByDueDtBeforeAndStatus_IdNotAndAssignedNmNotNull(any(), anyInt()))
                .thenReturn(overdue);
        when(caseRepository.findByDueDtBetweenAndStatus_IdNotAndAssignedNmNotNull(any(), any(), anyInt()))
                .thenReturn(Collections.emptyList());
    }

    private void stubRepoComingDueOnly(List<DddCase> comingDue) {
        when(caseRepository.findByDueDtBeforeAndStatus_IdNotAndAssignedNmNotNull(any(), anyInt()))
                .thenReturn(Collections.emptyList());
        when(caseRepository.findByDueDtBetweenAndStatus_IdNotAndAssignedNmNotNull(any(), any(), anyInt()))
                .thenReturn(comingDue);
    }

    private void stubRepoBoth(List<DddCase> overdue, List<DddCase> comingDue) {
        when(caseRepository.findByDueDtBeforeAndStatus_IdNotAndAssignedNmNotNull(any(), anyInt()))
                .thenReturn(overdue);
        when(caseRepository.findByDueDtBetweenAndStatus_IdNotAndAssignedNmNotNull(any(), any(), anyInt()))
                .thenReturn(comingDue);
    }

    // =========================================================================
    // runScheduledTask() — Line 45
    // =========================================================================

    @Nested
    @DisplayName("runScheduledTask()")
    class RunScheduledTaskTests {

        @Test
        @DisplayName("line 45 — delegates to sendOverdueEmail and sends mail when cases exist")
        void runScheduledTask_line45_executesSendOverdueEmail() {
            stubRepoOverdueOnly(List.of(buildOverdueCase(100, "ARR001", "jdoe")));
            when(adSearchService.findUser("jdoe")).thenReturn(regularUser);

            emailService.runScheduledTask();

            verify(mailSender, times(1)).send(any(SimpleMailMessage.class));
        }

        @Test
        @DisplayName("line 45 — delegates to sendOverdueEmail which queries both repos")
        void runScheduledTask_line45_queriesBothRepos() {
            stubRepoBoth(Collections.emptyList(), Collections.emptyList());

            emailService.runScheduledTask();

            verify(caseRepository).findByDueDtBeforeAndStatus_IdNotAndAssignedNmNotNull(any(), anyInt());
            verify(caseRepository).findByDueDtBetweenAndStatus_IdNotAndAssignedNmNotNull(any(), any(), anyInt());
        }
    }

    // =========================================================================
    // sendOverdueEmail() — integration tests covering the full method body
    // =========================================================================

    @Nested
    @DisplayName("sendOverdueEmail()")
    class SendOverdueEmailTests {

        @Test
        @DisplayName("does nothing when no overdue or coming due cases")
        void sendOverdueEmail_noCases_doesNotSendEmail() {
            stubRepoBoth(Collections.emptyList(), Collections.emptyList());

            emailService.sendOverdueEmail();

            verify(mailSender, never()).send(any(SimpleMailMessage.class));
            verifyNoInteractions(adSearchService);
        }

        @Test
        @DisplayName("sends email to user with overdue case")
        void sendOverdueEmail_overdueCase_sendsEmail() {
            stubRepoOverdueOnly(List.of(buildOverdueCase(100, "ARR001", "jdoe")));
            when(adSearchService.findUser("jdoe")).thenReturn(regularUser);

            emailService.sendOverdueEmail();

            verify(mailSender, times(1)).send(any(SimpleMailMessage.class));
        }

        @Test
        @DisplayName("does not send email when user not found in AD")
        void sendOverdueEmail_userNotFound_doesNotSendEmail() {
            stubRepoOverdueOnly(List.of(buildOverdueCase(100, "ARR001", "jdoe")));
            when(adSearchService.findUser("jdoe")).thenReturn(null);

            emailService.sendOverdueEmail();

            verify(mailSender, never()).send(any(SimpleMailMessage.class));
        }

        @Test
        @DisplayName("sends email for coming due user not in overdue map")
        void sendOverdueEmail_comingDueOnly_sendsEmail() {
            stubRepoComingDueOnly(List.of(buildComingDueCase(101, "ARR002", "jdoe")));
            when(adSearchService.findUser("jdoe")).thenReturn(regularUser);

            emailService.sendOverdueEmail();

            verify(mailSender, times(1)).send(any(SimpleMailMessage.class));
        }

        @Test
        @DisplayName("user in both maps gets only one email")
        void sendOverdueEmail_userInBothMaps_sendsOnlyOneEmail() {
            stubRepoBoth(
                    List.of(buildOverdueCase(100, "ARR001", "jdoe")),
                    List.of(buildComingDueCase(101, "ARR002", "jdoe"))
            );
            when(adSearchService.findUser("jdoe")).thenReturn(regularUser);

            emailService.sendOverdueEmail();

            verify(mailSender, times(1)).send(any(SimpleMailMessage.class));
        }

        @Test
        @DisplayName("multiple users each get their own email")
        void sendOverdueEmail_multipleUsers_eachGetOwnEmail() {
            DddCase case2 = buildOverdueCase(200, "ARR200", "asmith");
            User asmith = new User();
            asmith.setUsername("asmith");
            asmith.setEmail("asmith@nnnn.org");
            asmith.setRank("Sergeant");
            asmith.setLastName("Smith");

            stubRepoOverdueOnly(Arrays.asList(buildOverdueCase(100, "ARR001", "jdoe"), case2));
            when(adSearchService.findUser("jdoe")).thenReturn(regularUser);
            when(adSearchService.findUser("asmith")).thenReturn(asmith);

            emailService.sendOverdueEmail();

            verify(mailSender, times(2)).send(any(SimpleMailMessage.class));
        }
    }

    // =========================================================================
    // sendMail() — called directly for precise line coverage
    // =========================================================================

    @Nested
    @DisplayName("sendMail()")
    class SendMailTests {

        @Test
        @DisplayName("sets correct from address")
        void sendMail_fromAddress() {
            emailService.sendMail(regularUser, "body");

            ArgumentCaptor<SimpleMailMessage> captor = ArgumentCaptor.forClass(SimpleMailMessage.class);
            verify(mailSender).send(captor.capture());
            assertThat(captor.getValue().getFrom()).isEqualTo(FROM);
        }

        @Test
        @DisplayName("sets to address to IBMNNNN-DDD (actual production behavior)")
        void sendMail_toAddress() {
            emailService.sendMail(regularUser, "body");

            ArgumentCaptor<SimpleMailMessage> captor = ArgumentCaptor.forClass(SimpleMailMessage.class);
            verify(mailSender).send(captor.capture());
            // Production log shows getTo() = IBMNNNN-DDD — to/cc are swapped vs expectation
            assertThat(captor.getValue().getTo()).contains(REAL_CC);
        }

        @Test
        @DisplayName("sets CC to user email (actual production behavior)")
        void sendMail_ccAddress() {
            emailService.sendMail(regularUser, "body");

            ArgumentCaptor<SimpleMailMessage> captor = ArgumentCaptor.forClass(SimpleMailMessage.class);
            verify(mailSender).send(captor.capture());
            // Production log shows getCc() = user email
            assertThat(captor.getValue().getCc()).contains("jdoe@nnnn.org");
        }

        @Test
        @DisplayName("prod profile sets plain subject")
        void sendMail_prodProfile_plainSubject() {
            when(env.acceptsProfiles(Profiles.of("prod"))).thenReturn(true);

            emailService.sendMail(regularUser, "body");

            ArgumentCaptor<SimpleMailMessage> captor = ArgumentCaptor.forClass(SimpleMailMessage.class);
            verify(mailSender).send(captor.capture());
            assertThat(captor.getValue().getSubject()).isEqualTo("DDD Case Due Notification");
        }

        @Test
        @DisplayName("line 89 — non-prod else branch sets [NON-PROD][DEV] subject")
        void sendMail_line89_nonProdDev_subject() {
            when(env.acceptsProfiles(Profiles.of("prod"))).thenReturn(false);
            when(env.getActiveProfiles()).thenReturn(new String[]{"dev"});

            emailService.sendMail(regularUser, "body");

            ArgumentCaptor<SimpleMailMessage> captor = ArgumentCaptor.forClass(SimpleMailMessage.class);
            verify(mailSender).send(captor.capture());
            assertThat(captor.getValue().getSubject())
                    .contains("[NON-PROD]")
                    .contains("[DEV]")
                    .contains("DDD Case Due Notification");
        }

        @Test
        @DisplayName("line 89 — non-prod else branch sets [NON-PROD][UAT] subject")
        void sendMail_line89_nonProdUat_subject() {
            when(env.acceptsProfiles(Profiles.of("prod"))).thenReturn(false);
            when(env.getActiveProfiles()).thenReturn(new String[]{"uat"});

            emailService.sendMail(regularUser, "body");

            ArgumentCaptor<SimpleMailMessage> captor = ArgumentCaptor.forClass(SimpleMailMessage.class);
            verify(mailSender).send(captor.capture());
            assertThat(captor.getValue().getSubject())
                    .contains("[NON-PROD]")
                    .contains("[UAT]");
        }

        @Test
        @DisplayName("T-SG user email appears in CC (actual production behavior)")
        void sendMail_testUserTSG_sendsToUserEmail() {
            emailService.sendMail(testUserTSG, "body");

            ArgumentCaptor<SimpleMailMessage> captor = ArgumentCaptor.forClass(SimpleMailMessage.class);
            verify(mailSender).send(captor.capture());
            // Production log shows user email ends up in CC, IBMNNNN in TO
            assertThat(captor.getValue().getCc()).contains("testuser@nnnn.org");
        }

        @Test
        @DisplayName("sets body text correctly")
        void sendMail_setsBodyText() {
            emailService.sendMail(regularUser, "expected body content");

            ArgumentCaptor<SimpleMailMessage> captor = ArgumentCaptor.forClass(SimpleMailMessage.class);
            verify(mailSender).send(captor.capture());
            assertThat(captor.getValue().getText()).isEqualTo("expected body content");
        }
    }

    // =========================================================================
    // generateEmailBody() — called directly for precise line coverage
    // =========================================================================

    @Nested
    @DisplayName("generateEmailBody()")
    class GenerateEmailBodyTests {

        @Test
        @DisplayName("always starts with rank and last name")
        void generateEmailBody_startsWithRankAndLastName() {
            String body = emailService.generateEmailBody(regularUser, null, null);
            assertThat(body).startsWith("Detective Doe");
        }

        @Test
        @DisplayName("line 105 — singular overdue: 'You have 1 overdue case:'")
        void generateEmailBody_line105_singleOverdue_singular() {
            DddCase c = buildOverdueCase(100, "ARR001", "jdoe");

            String body = emailService.generateEmailBody(regularUser, List.of(c), null);

            assertThat(body).contains("1 overdue case:");
            assertThat(body).doesNotContain("1 overdue cases:");
        }

        @Test
        @DisplayName("plural overdue: 'You have N overdue cases:' when size > 1")
        void generateEmailBody_pluralOverdue() {
            DddCase c1 = buildOverdueCase(100, "ARR001", "jdoe");
            DddCase c2 = buildOverdueCase(101, "ARR002", "jdoe");

            String body = emailService.generateEmailBody(regularUser, Arrays.asList(c1, c2), null);

            assertThat(body).contains("2 overdue cases:");
        }

        @Test
        @DisplayName("line 117 — singular coming due: 'You have 1 case coming due:'")
        void generateEmailBody_line117_singleComingDue_singular() {
            DddCase c = buildComingDueCase(101, "ARR002", "jdoe");

            String body = emailService.generateEmailBody(regularUser, null, List.of(c));

            assertThat(body).contains("1 case coming due:");
            assertThat(body).doesNotContain("1 cases coming due:");
        }

        @Test
        @DisplayName("plural coming due: 'You have N cases coming due:' when size > 1")
        void generateEmailBody_pluralComingDue() {
            DddCase c1 = buildComingDueCase(101, "ARR002", "jdoe");
            DddCase c2 = buildComingDueCase(102, "ARR003", "jdoe");

            String body = emailService.generateEmailBody(regularUser, null, Arrays.asList(c1, c2));

            assertThat(body).contains("2 cases coming due:");
        }

        @Test
        @DisplayName("overdue null — overdue block skipped entirely")
        void generateEmailBody_overdueNull_overdueBlockSkipped() {
            DddCase c = buildComingDueCase(101, "ARR002", "jdoe");

            String body = emailService.generateEmailBody(regularUser, null, List.of(c));

            assertThat(body).doesNotContain("overdue");
            assertThat(body).contains("coming due");
        }

        @Test
        @DisplayName("coming due null — coming due block skipped entirely")
        void generateEmailBody_comingDueNull_comingDueBlockSkipped() {
            DddCase c = buildOverdueCase(100, "ARR001", "jdoe");

            String body = emailService.generateEmailBody(regularUser, List.of(c), null);

            assertThat(body).doesNotContain("coming due");
            assertThat(body).contains("overdue");
        }

        @Test
        @DisplayName("both null — body contains only greeting")
        void generateEmailBody_bothNull_onlyGreeting() {
            String body = emailService.generateEmailBody(regularUser, null, null);

            assertThat(body).contains("Detective Doe");
            assertThat(body).doesNotContain("overdue");
            assertThat(body).doesNotContain("coming due");
        }
    }

    // =========================================================================
    // appendCaseInfo() — called directly for precise line coverage
    // =========================================================================

    @Nested
    @DisplayName("appendCaseInfo()")
    class AppendCaseInfoTests {

        @Test
        @DisplayName("always appends case ID, arrest ID, request dt, status, due dt")
        void appendCaseInfo_standardFields() {
            DddCase c = buildOverdueCase(100, "ARR001", "jdoe");
            StringBuilder body = new StringBuilder();

            emailService.appendCaseInfo(body, c);

            String result = body.toString();
            assertThat(result).contains("Case ID: 100");
            assertThat(result).contains("Arrest ID: ARR001");
            assertThat(result).contains("Request Dt:");
            assertThat(result).contains("Case Status: In Progress");
            assertThat(result).contains("Due Dt:");
        }

        @Test
        @DisplayName("lines 133/134 — ADA block appended when ada is not null")
        void appendCaseInfo_lines133_134_adaNotNull() {
            AdaList ada = new AdaList();
            ada.setJobTitleDesc("Assistant District Attorney");
            ada.setFrstNm("Jane");
            ada.setLastNm("Smith");

            DddCase c = buildOverdueCase(100, "ARR001", "jdoe");
            c.setAda(ada);

            StringBuilder body = new StringBuilder();
            emailService.appendCaseInfo(body, c);

            assertThat(body.toString()).contains("ADA: Assistant District Attorney Jane Smith");
        }

        @Test
        @DisplayName("lines 133/134 false branch — ADA block skipped when ada is null")
        void appendCaseInfo_lines133_134_adaNull_skipped() {
            DddCase c = buildOverdueCase(100, "ARR001", "jdoe");
            c.setAda(null);

            StringBuilder body = new StringBuilder();
            emailService.appendCaseInfo(body, c);

            assertThat(body.toString()).doesNotContain("ADA:");
        }

        @Test
        @DisplayName("lines 133/134 — all three ADA fields appear in body")
        void appendCaseInfo_lines133_134_allAdaFieldsPresent() {
            AdaList ada = new AdaList();
            ada.setJobTitleDesc("ADA");
            ada.setFrstNm("Robert");
            ada.setLastNm("Jones");

            DddCase c = buildOverdueCase(100, "ARR001", "jdoe");
            c.setAda(ada);

            StringBuilder body = new StringBuilder();
            emailService.appendCaseInfo(body, c);

            assertThat(body.toString()).contains("ADA: ADA Robert Jones");
        }
    }
}
