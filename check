            when(authenticationService.isSupervisor()).thenReturn(false);
            stubSecurityContext(List.of(new SimpleGrantedAuthority("ROLE_SG-SEALED-EVENT")));

            List<DDDOffice> result = service.getDDDOffices("jdoe");

            assertThat(result).isEmpty();
            verify(dddOfficeListRepository, never()).findAllDTOForSG(any());
            SecurityContextHolder.clearContext();
        }

        @Test
        @DisplayName("non-supervisor with no authorities gets empty list")
        void getDDDOffices_nonSupervisor_noAuthorities_returnsEmptyList() {
            when(authenticationService.isSupervisor()).thenReturn(false);
            stubSecurityContext(Collections.emptyList());

            assertThat(service.getDDDOffices("jdoe")).isEmpty();
            SecurityContextHolder.clearContext();
        }

        @Test
        @DisplayName("non-supervisor with multiple DDD roles aggregates all offices")
        void getDDDOffices_nonSupervisor_multipleDDDRoles_aggregatesOffices() {
            String role1 = "ROLE_SG-DDD-ANALYST-BROOKLYN";
            String role2 = "ROLE_SG-DDD-ANALYST-BRONX";
            DDDOffice office1 = new DDDOffice();
            DDDOffice office2 = new DDDOffice();

            when(authenticationService.isSupervisor()).thenReturn(false);
            stubSecurityContext(List.of(
                    new SimpleGrantedAuthority(role1),
                    new SimpleGrantedAuthority(role2)
            ));
            when(dddOfficeListRepository.findAllDTOForSG(role1)).thenReturn(List.of(office1));
            when(dddOfficeListRepository.findAllDTOForSG(role2)).thenReturn(List.of(office2));

            List<DDDOffice> result = service.getDDDOffices("jdoe");

            assertThat(result).hasSize(2).contains(office1, office2);
            SecurityContextHolder.clearContext();
        }

        // Helper — stubs SecurityContextHolder with the given authorities
        @SuppressWarnings("unchecked")
        private void stubSecurityContext(
                java.util.Collection<? extends org.springframework.security.core.GrantedAuthority> authorities) {
            Authentication auth = mock(Authentication.class);
            when(auth.getAuthorities()).thenReturn((Collection) authorities);
            SecurityContext ctx = mock(SecurityContext.class);
            when(ctx.getAuthentication()).thenReturn(auth);
            SecurityContextHolder.setContext(ctx);
        }
    }

