@DisplayName("saveCase - filter skips entityTag when getTag() is null)")
void saveCase_existingTagWithNullTagReference_createsNewTag() {
    dtoCase.setId(100);

    // Entity has a CaseTag whose tag reference is null (orphaned row)
    CaseTag orphanTag = new CaseTag();
    orphanTag.setId(99);
    orphanTag.setTag(null); // ← entityTag.getTag() == null
    entityCase.getTags().add(orphanTag);

    org.nnnn.ddd.model.CaseTag dtoTag = new org.nnnn.ddd.model.CaseTag();
    dtoTag.setTagId(5);
    dtoCase.setTags(List.of(dtoTag));

    TagList tagEntity = new TagList();
    tagEntity.setId(5);

    stubFindById(100);
    when(tagListRepository.findById(5)).thenReturn(Optional.of(tagEntity));

    caseService.saveCase(dtoCase);

    // A new CaseTag was created because the orphan was filtered out
