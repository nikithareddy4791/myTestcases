@Import({TestConfig.class, CaseApiController.class, GlobalExceptionHandler.class})
@org.springframework.boot.test.autoconfigure.web.servlet.AutoConfigureMockMvc(addFilters = false)
@DisplayName("CaseApiController Tests")
public class CaseApiControllerTest {

    @Autowired
    private MockMvc mockMvc;

    @Autowired
    private ObjectMapper objectMapper;

    @MockBean
    private CaseService caseService;

    @MockBean
    private AuthenticationService authenticationService;

    @MockBean
    private AuditService auditService;

    @MockBean
    private javax.sql.DataSource dataSource;

    // -------------------------------------------------------------------------
    // Helpers
    // -------------------------------------------------------------------------

    private String validCreateCaseRequestJson() throws Exception {
        CreateCaseRequest req = new CreateCaseRequest();
        req.setArrId("ARR001");
        req.setDddOfficeId(1);
        req.setProactiveFlg(0);
        return objectMapper.writeValueAsString(req);
    }

    private String validIntakeFilterJson() throws Exception {
        IntakeFilter filter = new IntakeFilter();
        filter.setArrDtFrom("2024-01-01");
        filter.setArrDtTo("2024-12-31");
        return objectMapper.writeValueAsString(filter);
    }

    // =========================================================================
    // POST /case — createCaseByArrest()
    // Lines 116 (CREATED), 117 (OK), 118 (rethrow)
    // =========================================================================

    @Test
    @DisplayName("POST /case - new case returns 201 CREATED (line 116)")
    void createCase_newCase_returns201() throws Exception {
        DDDCase result = new DDDCase();
        result.setId(1);
        result.setNew(true);
        when(caseService.createCase(any())).thenReturn(result);

        mockMvc.perform(post("/case")
                .contentType(MediaType.APPLICATION_JSON)
                .accept(MediaType.APPLICATION_JSON)
                .content(validCreateCaseRequestJson()))
                .andExpect(status().isCreated());
    }

    @Test
    @DisplayName("POST /case - existing case returns 200 OK (line 117)")
    void createCase_existingCase_returns200() throws Exception {
        DDDCase result = new DDDCase();
        result.setId(1);
        result.setNew(false);
        when(caseService.createCase(any())).thenReturn(result);

        mockMvc.perform(post("/case")
                .contentType(MediaType.APPLICATION_JSON)
                .accept(MediaType.APPLICATION_JSON)
                .content(validCreateCaseRequestJson()))
                .andExpect(status().isOk());
    }

    @Test
    @DisplayName("POST /case - SealedAccessException rethrown → 403 (line 118)")
    void createCase_sealedAccessException_returns403() throws Exception {
        when(caseService.createCase(any()))
                .thenThrow(new SealedAccessException("no sealed access"));

        mockMvc.perform(post("/case")
                .contentType(MediaType.APPLICATION_JSON)
                .accept(MediaType.APPLICATION_JSON)
                .content(validCreateCaseRequestJson()))
                .andExpect(status().isForbidden());
    }

    @Test
    @DisplayName("POST /case - InvalidArrestException rethrown → 500 (line 118)")
    void createCase_invalidArrestException_returns500() throws Exception {
        when(caseService.createCase(any()))
                .thenThrow(new InvalidArrestException("arrest not found"));

        mockMvc.perform(post("/case")
                .contentType(MediaType.APPLICATION_JSON)
                .accept(MediaType.APPLICATION_JSON)
                .content(validCreateCaseRequestJson()))
                .andExpect(status().isInternalServerError());
    }

    @Test
    @DisplayName("POST /case - generic exception returns 500")
    void createCase_genericException_returns500() throws Exception {
        when(caseService.createCase(any()))
                .thenThrow(new RuntimeException("unexpected"));

        mockMvc.perform(post("/case")
                .contentType(MediaType.APPLICATION_JSON)
                .accept(MediaType.APPLICATION_JSON)
                .content(validCreateCaseRequestJson()))
                .andExpect(status().isInternalServerError());
    }

    @Test
    @DisplayName("POST /case - no Accept header returns 501")
    void createCase_noAcceptHeader_returns501() throws Exception {
        when(caseService.createCase(any())).thenReturn(new DDDCase());

        mockMvc.perform(post("/case")
                .contentType(MediaType.APPLICATION_JSON)
                .content(validCreateCaseRequestJson()))
                .andExpect(status().isNotImplemented());
    }

    // =========================================================================
