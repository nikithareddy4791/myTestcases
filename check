    /**
     * Builds a CreateCaseRequest JSON with all fields populated.
     * If your @Valid constraints require more fields, add them here.
     * If you still get 400, share CreateCaseRequest.java so we can see @NotNull fields.
     */
    private String validCreateCaseRequestJson() throws Exception {
        CreateCaseRequest req = new CreateCaseRequest();
        req.setArrId("ARR001");
        req.setDddOfficeId(1);
        req.setProactiveFlg(0);
        // If requestDt / dueDt are @NotNull, uncomment:
        // req.setRequestDt(org.threeten.bp.LocalDate.now());
        // req.setDueDt(org.threeten.bp.LocalDate.now().plusDays(30));
        return objectMapper.writeValueAsString(req);
    }

    private String validIntakeFilterJson() throws Exception {
        IntakeFilter filter = new IntakeFilter();
        filter.setArrDtFrom("2024-01-01");
        filter.setArrDtTo("2024-12-31");
        return objectMapper.writeValueAsString(filter);
    }

    // =========================================================================
    // POST /case — createCaseByArrest()
    // Lines 116 (CREATED), 117 (OK), 118 (SealedAccess/InvalidArrest rethrow)
    // =========================================================================

    @Test
    @WithMockUser
    @DisplayName("POST /case - new case returns 201 CREATED (line 116)")
    void createCase_newCase_returns201() throws Exception {
        DDDCase result = new DDDCase();
        result.setId(1);
        result.setNew(true);
        when(caseService.createCase(any())).thenReturn(result);

        mockMvc.perform(post("/case")
                .with(csrf())
                .contentType(MediaType.APPLICATION_JSON)
                .accept(MediaType.APPLICATION_JSON)
                .content(validCreateCaseRequestJson()))
                .andExpect(status().isCreated());
    }

    @Test
    @WithMockUser
    @DisplayName("POST /case - existing case returns 200 OK (line 117)")
    void createCase_existingCase_returns200() throws Exception {
        DDDCase result = new DDDCase();
        result.setId(1);
        result.setNew(false);
        when(caseService.createCase(any())).thenReturn(result);

        mockMvc.perform(post("/case")
                .with(csrf())
                .contentType(MediaType.APPLICATION_JSON)
                .accept(MediaType.APPLICATION_JSON)
                .content(validCreateCaseRequestJson()))
                .andExpect(status().isOk());
    }

    @Test
    @WithMockUser
    @DisplayName("POST /case - SealedAccessException rethrown (line 118) - covers catch block")
    void createCase_sealedAccessException_coversCatchBlock() throws Exception {
        when(caseService.createCase(any()))
                .thenThrow(new SealedAccessException("no sealed access"));

        // Controller rethrows — GlobalExceptionHandler determines final status.
        // We accept any non-2xx to confirm the catch block was entered and rethrown.
        mockMvc.perform(post("/case")
                .with(csrf())
                .contentType(MediaType.APPLICATION_JSON)
                .accept(MediaType.APPLICATION_JSON)
                .content(validCreateCaseRequestJson()))
                .andExpect(status().is(
                        org.hamcrest.Matchers.not(
                                org.hamcrest.Matchers.anyOf(
                                        org.hamcrest.Matchers.is(200),
                                        org.hamcrest.Matchers.is(201)))));
    }

    @Test
    @WithMockUser
    @DisplayName("POST /case - InvalidArrestException rethrown (line 118) - covers catch block")
    void createCase_invalidArrestException_coversCatchBlock() throws Exception {
        when(caseService.createCase(any()))
                .thenThrow(new InvalidArrestException("arrest not found"));

        mockMvc.perform(post("/case")
                .with(csrf())
                .contentType(MediaType.APPLICATION_JSON)
                .accept(MediaType.APPLICATION_JSON)
                .content(validCreateCaseRequestJson()))
                .andExpect(status().is(
                        org.hamcrest.Matchers.not(
                                org.hamcrest.Matchers.anyOf(
                                        org.hamcrest.Matchers.is(200),
                                        org.hamcrest.Matchers.is(201)))));
    }

    @Test
    @WithMockUser
    @DisplayName("POST /case - generic exception returns 500 (catch Exception block)")
    void createCase_genericException_returns500() throws Exception {
        when(caseService.createCase(any()))
                .thenThrow(new RuntimeException("unexpected error"));

        mockMvc.perform(post("/case")
                .with(csrf())
                .contentType(MediaType.APPLICATION_JSON)
                .accept(MediaType.APPLICATION_JSON)
                .content(validCreateCaseRequestJson()))
                .andExpect(status().isInternalServerError());
    }

    @Test
    @WithMockUser
    @DisplayName("POST /case - no Accept header returns 501 (NOT_IMPLEMENTED)")
    void createCase_noAcceptHeader_returns501() throws Exception {
        when(caseService.createCase(any())).thenReturn(new DDDCase());

        mockMvc.perform(post("/case")
                .with(csrf())
                .contentType(MediaType.APPLICATION_JSON)
                // deliberately omit .accept() so Accept header is not application/json
                .content(validCreateCaseRequestJson()))
                .andExpect(status().isNotImplemented());
    }

    @Test
    @DisplayName("POST /case - unauthenticated returns 401")
    void createCase_noAuth_returns401() throws Exception {
        mockMvc.perform(post("/case")
                .with(csrf())
                .contentType(MediaType.APPLICATION_JSON)
                .accept(MediaType.APPLICATION_JSON)
                .content(validCreateCaseRequestJson()))
                .andExpect(status().isUnauthorized());
    }

