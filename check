    // =========================================================================
    // getRefCodeByType()
    // ReferenceCode only has a 4-arg constructor:
    //   new ReferenceCode(Integer id, String codeType, String codeVal, String codeDesc)
    // =========================================================================

    @Nested
    @DisplayName("getRefCodeByType()")
    class GetRefCodeByTypeTests {

        @Test
        @DisplayName("delegates to repository and returns results")
        void getRefCodeByType_returnsRepositoryResults() {
            ReferenceCode code = new ReferenceCode(1, "CHARGE_TYPE", "F", "Felony");
            when(codeRefRepository.findDTOByCodeTypeOrderByIdAsc("CHARGE_TYPE"))
                    .thenReturn(List.of(code));

            List<ReferenceCode> result = service.getRefCodeByType("CHARGE_TYPE");

            assertThat(result).hasSize(1);
            assertThat(result.get(0).getId()).isEqualTo(1);
            assertThat(result.get(0).getCodeType()).isEqualTo("CHARGE_TYPE");
            assertThat(result.get(0).getCodeVal()).isEqualTo("F");
            assertThat(result.get(0).getCodeDesc()).isEqualTo("Felony");
            verify(codeRefRepository).findDTOByCodeTypeOrderByIdAsc("CHARGE_TYPE");
        }

        @Test
        @DisplayName("returns empty list when no codes found for type")
        void getRefCodeByType_noResults_returnsEmptyList() {
            when(codeRefRepository.findDTOByCodeTypeOrderByIdAsc("UNKNOWN"))
                    .thenReturn(Collections.emptyList());

            assertThat(service.getRefCodeByType("UNKNOWN")).isEmpty();
        }

        @Test
        @DisplayName("returns multiple codes for a given type")
        void getRefCodeByType_multipleResults_returnsAll() {
            ReferenceCode code1 = new ReferenceCode(1, "CHARGE_TYPE", "F", "Felony");
            ReferenceCode code2 = new ReferenceCode(2, "CHARGE_TYPE", "M", "Misdemeanor");
            when(codeRefRepository.findDTOByCodeTypeOrderByIdAsc("CHARGE_TYPE"))
                    .thenReturn(List.of(code1, code2));

            List<ReferenceCode> result = service.getRefCodeByType("CHARGE_TYPE");

            assertThat(result).hasSize(2);
            assertThat(result.get(0).getCodeVal()).isEqualTo("F");
            assertThat(result.get(1).getCodeVal()).isEqualTo("M");
        }
    }

