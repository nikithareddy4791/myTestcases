package org.nnnn.ddd.api;

import org.nnnn.ddd.model.ADA;
import org.nnnn.ddd.model.Item;
import org.nnnn.ddd.model.Tag;
import org.nnnn.ddd.service.AuthenticationService;
import org.nnnn.ddd.service.ReferenceDataService;

import com.fasterxml.jackson.databind.ObjectMapper;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;

import jakarta.servlet.http.HttpServletRequest;
import java.util.List;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class ReferenceApiControllerSaveTest {

    @Mock
    private ReferenceDataService referenceDataService;

    @Mock
    private AuthenticationService authenticationService;

    @Mock
    private HttpServletRequest request;

    @Mock
    private ObjectMapper objectMapper;

    @InjectMocks
    private ReferenceApiController controller;

    // ─────────────────────────────────────────────────────────────
    // saveADAList
    // ─────────────────────────────────────────────────────────────

    @Test
    void saveADAList_returnsOkWithUpdatedList_whenAcceptIsJson() throws Exception {
        ADA ada = new ADA();
        List<ADA> input = List.of(ada);
        List<ADA> saved = List.of(ada);

        when(request.getHeader("Accept")).thenReturn("application/json");
        when(referenceDataService.updateAdas(input)).thenReturn(saved);

        ResponseEntity<List<ADA>> response = controller.saveADAList(input);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals(saved, response.getBody());
        verify(referenceDataService).updateAdas(input);
    }

    @Test
    void saveADAList_returnsInternalServerError_whenServiceThrows() throws Exception {
        List<ADA> input = List.of(new ADA());

        when(request.getHeader("Accept")).thenReturn("application/json");
        when(referenceDataService.updateAdas(input)).thenThrow(new RuntimeException("DB error"));

        ResponseEntity<List<ADA>> response = controller.saveADAList(input);

        assertEquals(HttpStatus.INTERNAL_SERVER_ERROR, response.getStatusCode());
    }

    @Test
    void saveADAList_returnsNotImplemented_whenAcceptHeaderMissing() {
        when(request.getHeader("Accept")).thenReturn(null);

        ResponseEntity<List<ADA>> response = controller.saveADAList(List.of(new ADA()));

        assertEquals(HttpStatus.NOT_IMPLEMENTED, response.getStatusCode());
        verifyNoInteractions(referenceDataService);
    }

    @Test
    void saveADAList_returnsNotImplemented_whenAcceptIsNotJson() {
        when(request.getHeader("Accept")).thenReturn("text/html");

        ResponseEntity<List<ADA>> response = controller.saveADAList(List.of(new ADA()));

        assertEquals(HttpStatus.NOT_IMPLEMENTED, response.getStatusCode());
        verifyNoInteractions(referenceDataService);
    }

