    // =========================================================================
    // GET /case/{caseId}/file/{uploadId} — getCaseUploadById()
    // Correct URL from CaseApi interface: /case/{caseId}/file/{uploadId}
    // =========================================================================

    @Test
    @WithMockUser
    @DisplayName("GET /case/{caseId}/file/{uploadId} - returns file with Content-Disposition header")
    void getCaseUploadById_found_returnsFile() throws Exception {
        ByteArrayResource resource = new ByteArrayResource("file content".getBytes());
        when(caseService.getFile(100, 1))
                .thenReturn(new Object[]{"document.pdf", resource});

        mockMvc.perform(get("/case/100/file/1")
                .accept(MediaType.APPLICATION_JSON))
                .andExpect(status().isOk())
                .andExpect(header().string("Content-Disposition",
                        containsString("document.pdf")));
    }

    @Test
    @WithMockUser
