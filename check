        @Test
        @DisplayName("maps sealed flag Y from result row")
        @SuppressWarnings("rawtypes")
        void getArrestInfoSummary_list_mapsSealedFlagY() {
            Object[] row = buildRow(ARR_ID, "Assault", ARR_DATE, "John", "Doe", "NYSID123", 'Y');
