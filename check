        verify(caseService, never()).getCaseStats(anyString());
    }

    @Test
    @DisplayName("GET /case/stats - no Accept header returns 501 (no auth needed, filters disabled)")
    void getCaseStats_noAuth_returns401() throws Exception {
        mockMvc.perform(get("/case/stats"))
                .andExpect(status().isNotImplemented());

        verify(caseService, never()).getCaseStats(anyString());
    }
