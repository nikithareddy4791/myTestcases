import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.put;
import org.springframework.http.MediaType;

// =========================================================================
// PUT /reference/adas
// =========================================================================

@Test
@WithMockUser
void saveADAList_returnsOkWithList() throws Exception {
    when(referenceDataService.updateAdas(any())).thenReturn(Arrays.asList(mockAda));

    mockMvc.perform(put("/reference/adas")
            .contentType(MediaType.APPLICATION_JSON)
            .content(new ObjectMapper().writeValueAsString(Arrays.asList(mockAda)))
            .accept(MediaType.APPLICATION_JSON))
            .andExpect(status().isOk())
            .andExpect(jsonPath("$[0].id").value(1))
            .andExpect(jsonPath("$[0].frstNm").value("Jane"));

    verify(referenceDataService, times(1)).updateAdas(any());
}

@Test
@WithMockUser
void saveADAList_serviceThrowsException_returns500() throws Exception {
    when(referenceDataService.updateAdas(any())).thenThrow(new RuntimeException("DB error"));

    mockMvc.perform(put("/reference/adas")
            .contentType(MediaType.APPLICATION_JSON)
            .content(new ObjectMapper().writeValueAsString(Arrays.asList(mockAda)))
            .accept(MediaType.APPLICATION_JSON))
            .andExpect(status().isInternalServerError());
}

@Test
void saveADAList_noAuth_returns401() throws Exception {
    mockMvc.perform(put("/reference/adas")
            .contentType(MediaType.APPLICATION_JSON)
            .content(new ObjectMapper().writeValueAsString(Arrays.asList(mockAda)))
            .accept(MediaType.APPLICATION_JSON))
            .andExpect(status().isUnauthorized());
}

@Test
@WithMockUser
void saveADAList_noAcceptHeader_returns501() throws Exception {
    mockMvc.perform(put("/reference/adas")
            .contentType(MediaType.APPLICATION_JSON)
            .content(new ObjectMapper().writeValueAsString(Arrays.asList(mockAda))))
            .andExpect(status().isNotImplemented());
}

