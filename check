package org.nnnn.ddd.service;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.mockito.junit.jupiter.MockitoSettings;
import org.mockito.quality.Strictness;
import org.nnnn.ddd.AppConstants;
import org.nnnn.ddd.entity.AdaList;
import org.nnnn.ddd.entity.DddCase;
import org.nnnn.ddd.entity.StatusList;
import org.nnnn.ddd.model.User;
import org.nnnn.ddd.repository.CaseRepository;
import org.springframework.core.env.Environment;
import org.springframework.core.env.Profiles;
import org.springframework.mail.SimpleMailMessage;
import org.springframework.mail.javamail.JavaMailSenderImpl;

import java.time.LocalDate;
import java.util.Arrays;
import java.util.List;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.Mockito.*;

/**
 * Calls generateEmailBody() and sendMail() and appendCaseInfo() DIRECTLY
 * so JaCoCo instruments the exact lines without going through sendOverdueEmail().
 *
 *   Line 89   — sendMail() non-prod subject else branch
 *   Line 105  — generateEmailBody() singular overdue "1 overdue case:"
 *   Line 117  — generateEmailBody() singular coming due "1 case coming due:"
 *   Lines 133/134 — appendCaseInfo() ADA block when ada != null
 */
@ExtendWith(MockitoExtension.class)
@MockitoSettings(strictness = Strictness.LENIENT)
@DisplayName("EmailService Direct Method Coverage Tests")
public class EmailServiceDirectCoverageTest {

    @Mock private CaseRepository     caseRepository;
    @Mock private ADSearchService    adSearchService;
    @Mock private JavaMailSenderImpl mailSender;
    @Mock private Environment        env;

    @InjectMocks
    private EmailService emailService;

    private User       regularUser;
    private User       testUserTSG;
    private StatusList statusInProgress;

    @BeforeEach
    void setUp() {
        statusInProgress = new StatusList();
        statusInProgress.setId(AppConstants.STATUS_IN_PROGRESS);
        statusInProgress.setStatusDesc("In Progress");

        regularUser = new User();
        regularUser.setUsername("jdoe");
        regularUser.setFirstName("John");
        regularUser.setLastName("Doe");
        regularUser.setEmail("jdoe@nnnn.org");
        regularUser.setRank("Detective");

        testUserTSG = new User();
        testUserTSG.setUsername("T-SG-testuser");
        testUserTSG.setEmail("testuser@nnnn.org");
        testUserTSG.setRank("Sgt");
        testUserTSG.setLastName("Testuser");

        lenient().when(env.acceptsProfiles(Profiles.of("prod"))).thenReturn(false);
        lenient().when(env.getActiveProfiles()).thenReturn(new String[]{"dev"});

        jakarta.mail.Session mockSession = mock(jakarta.mail.Session.class);
        lenient().when(mailSender.getSession()).thenReturn(mockSession);
    }

    // -------------------------------------------------------------------------
    // Helper
    // -------------------------------------------------------------------------

    private DddCase buildCase(int id, String arrId, String assignedNm) {
        DddCase c = new DddCase();
        c.setId(id);
        c.setArrId(arrId);
        c.setAssignedNm(assignedNm);
        c.setStatus(statusInProgress);
        c.setRequestDt(java.sql.Date.valueOf(LocalDate.now().minusDays(10)));
        c.setDueDt(java.sql.Date.valueOf(LocalDate.now().plusDays(2)));
        return c;
    }

    // =========================================================================
    // Line 89 — sendMail() non-prod else branch
    // Calling sendMail() directly so JaCoCo sees line 89 execute
    // =========================================================================

    @Test
    @DisplayName("sendMail - line 89 non-prod else branch sets [NON-PROD][DEV] subject (direct call)")
    void sendMail_line89_nonProdSubject_directCall() {
        when(env.acceptsProfiles(Profiles.of("prod"))).thenReturn(false);
        when(env.getActiveProfiles()).thenReturn(new String[]{"dev"});

        // Call sendMail() directly — JaCoCo instruments line 89 directly
        emailService.sendMail(regularUser, "test body");

        // Capture what was sent
        org.mockito.ArgumentCaptor<SimpleMailMessage> captor =
                org.mockito.ArgumentCaptor.forClass(SimpleMailMessage.class);
        verify(mailSender).send(captor.capture());

        // Line 89: "[NON-PROD][DEV] DDD Case Due Notification"
        assertThat(captor.getValue().getSubject())
                .contains("[NON-PROD]")
                .contains("[DEV]")
                .contains("DDD Case Due Notification");
    }

    @Test
    @DisplayName("sendMail - line 89 non-prod else branch with UAT profile (direct call)")
    void sendMail_line89_nonProdSubjectUat_directCall() {
        when(env.acceptsProfiles(Profiles.of("prod"))).thenReturn(false);
        when(env.getActiveProfiles()).thenReturn(new String[]{"uat"});

        emailService.sendMail(regularUser, "test body");

        org.mockito.ArgumentCaptor<SimpleMailMessage> captor =
                org.mockito.ArgumentCaptor.forClass(SimpleMailMessage.class);
        verify(mailSender).send(captor.capture());

        assertThat(captor.getValue().getSubject())
                .contains("[NON-PROD]")
                .contains("[UAT]");
    }

    @Test
    @DisplayName("sendMail - prod branch sets plain subject (direct call)")
    void sendMail_prodSubject_directCall() {
        when(env.acceptsProfiles(Profiles.of("prod"))).thenReturn(true);

        emailService.sendMail(regularUser, "test body");

        org.mockito.ArgumentCaptor<SimpleMailMessage> captor =
                org.mockito.ArgumentCaptor.forClass(SimpleMailMessage.class);
        verify(mailSender).send(captor.capture());

        assertThat(captor.getValue().getSubject()).isEqualTo("DDD Case Due Notification");
    }

    @Test
    @DisplayName("sendMail - sets correct from, to, and cc (direct call)")
    void sendMail_fromToCc_directCall() {
        emailService.sendMail(regularUser, "test body");

        org.mockito.ArgumentCaptor<SimpleMailMessage> captor =
                org.mockito.ArgumentCaptor.forClass(SimpleMailMessage.class);
        verify(mailSender).send(captor.capture());

        assertThat(captor.getValue().getFrom()).isEqualTo("DDD-Notification@nnnn.org");
        assertThat(captor.getValue().getTo()).contains("jdoe@nnnn.org");
        assertThat(captor.getValue().getCc()).contains("IBMNNNN-DDD@wwpdl.vnet.ibm.com");
    }

    @Test
    @DisplayName("sendMail - T-SG user isTest flag computed but routing unchanged (direct call)")
    void sendMail_testUserTSG_directCall() {
        emailService.sendMail(testUserTSG, "test body");

        org.mockito.ArgumentCaptor<SimpleMailMessage> captor =
                org.mockito.ArgumentCaptor.forClass(SimpleMailMessage.class);
        verify(mailSender).send(captor.capture());

        assertThat(captor.getValue().getTo()).contains("testuser@nnnn.org");
    }

    // =========================================================================
    // Line 105 — generateEmailBody() singular overdue "1 overdue case:"
    // Calling generateEmailBody() directly so JaCoCo sees line 105 execute
    // =========================================================================

    @Test
    @DisplayName("generateEmailBody - line 105 singular overdue 'case' not 'cases' (direct call)")
    void generateEmailBody_line105_singleOverdue_directCall() {
        DddCase overdueCase = buildCase(100, "ARR001", "jdoe");

        // Direct call — exactly 1 overdue → size > 1 is false → line 105 fires
        String body = emailService.generateEmailBody(
                regularUser,
                List.of(overdueCase),   // 1 overdue case → singular branch
                null
        );

        // Line 105: "You have 1 overdue case:" (singular)
        assertThat(body).contains("1 overdue case:");
        assertThat(body).doesNotContain("1 overdue cases:");
    }

    @Test
    @DisplayName("generateEmailBody - line 105 singular overdue body contains case details (direct call)")
    void generateEmailBody_line105_singleOverdue_bodyDetails_directCall() {
        DddCase overdueCase = buildCase(200, "ARR200", "jdoe");

        String body = emailService.generateEmailBody(
                regularUser,
                List.of(overdueCase),
                null
        );

        assertThat(body).contains("Case ID: 200");
        assertThat(body).contains("Arrest ID: ARR200");
        assertThat(body).contains("Detective Doe");
    }

    // =========================================================================
    // Line 117 — generateEmailBody() singular coming due "1 case coming due:"
    // Calling generateEmailBody() directly so JaCoCo sees line 117 execute
    // =========================================================================

    @Test
    @DisplayName("generateEmailBody - line 117 singular coming due 'case' not 'cases' (direct call)")
    void generateEmailBody_line117_singleComingDue_directCall() {
        DddCase comingDueCase = buildCase(101, "ARR002", "jdoe");

        // Direct call — exactly 1 coming due → size > 1 is false → line 117 fires
        String body = emailService.generateEmailBody(
                regularUser,
                null,
                List.of(comingDueCase)  // 1 coming due case → singular branch
        );

        // Line 117: "You have 1 case coming due:" (singular)
        assertThat(body).contains("1 case coming due:");
        assertThat(body).doesNotContain("1 cases coming due:");
    }

    @Test
    @DisplayName("generateEmailBody - line 117 singular coming due body contains case details (direct call)")
    void generateEmailBody_line117_singleComingDue_bodyDetails_directCall() {
        DddCase comingDueCase = buildCase(300, "ARR300", "jdoe");

        String body = emailService.generateEmailBody(
                regularUser,
                null,
                List.of(comingDueCase)
        );

        assertThat(body).contains("Case ID: 300");
        assertThat(body).contains("Arrest ID: ARR300");
    }

    @Test
    @DisplayName("generateEmailBody - plural coming due (size > 1) for completeness (direct call)")
    void generateEmailBody_pluralComingDue_directCall() {
        DddCase c1 = buildCase(101, "ARR002", "jdoe");
        DddCase c2 = buildCase(102, "ARR003", "jdoe");

        String body = emailService.generateEmailBody(
                regularUser,
                null,
                Arrays.asList(c1, c2)
        );

        assertThat(body).contains("2 cases coming due:");
    }

    // =========================================================================
    // Lines 133/134 — appendCaseInfo() ADA block when ada != null
    // Calling appendCaseInfo() directly so JaCoCo sees lines 133/134 execute
    // =========================================================================

    @Test
    @DisplayName("appendCaseInfo - lines 133/134 ADA block appended when ada is not null (direct call)")
    void appendCaseInfo_lines133_134_adaNotNull_directCall() {
        AdaList ada = new AdaList();
        ada.setJobTitleDesc("Assistant District Attorney");
        ada.setFrstNm("Jane");
        ada.setLastNm("Smith");

        DddCase caseWithAda = buildCase(400, "ARR400", "jdoe");
        caseWithAda.setAda(ada);    // ada != null → lines 133/134 fire

        StringBuilder body = new StringBuilder();
        // Direct call — JaCoCo instruments lines 133/134 directly
        emailService.appendCaseInfo(body, caseWithAda);

        // Lines 133/134: "ADA: <jobTitleDesc> <frstNm> <lastNm>"
        assertThat(body.toString()).contains("ADA: Assistant District Attorney Jane Smith");
    }

    @Test
    @DisplayName("appendCaseInfo - lines 133/134 all three ADA fields present (direct call)")
    void appendCaseInfo_lines133_134_allAdaFields_directCall() {
        AdaList ada = new AdaList();
        ada.setJobTitleDesc("ADA");
        ada.setFrstNm("Robert");
        ada.setLastNm("Jones");

        DddCase caseWithAda = buildCase(401, "ARR401", "jdoe");
        caseWithAda.setAda(ada);

        StringBuilder body = new StringBuilder();
        emailService.appendCaseInfo(body, caseWithAda);

        assertThat(body.toString()).contains("ADA:");
        assertThat(body.toString()).contains("Robert");
        assertThat(body.toString()).contains("Jones");
    }

    @Test
    @DisplayName("appendCaseInfo - ada null skips lines 133/134 (direct call)")
    void appendCaseInfo_adaNull_skipsAdaBlock_directCall() {
        DddCase caseNoAda = buildCase(402, "ARR402", "jdoe");
        caseNoAda.setAda(null);     // ada == null → if block skipped

        StringBuilder body = new StringBuilder();
        emailService.appendCaseInfo(body, caseNoAda);

        assertThat(body.toString()).doesNotContain("ADA:");
    }

    @Test
    @DisplayName("appendCaseInfo - always appends case ID, arrest ID, request dt, status, due dt (direct call)")
    void appendCaseInfo_alwaysAppendsStandardFields_directCall() {
        DddCase c = buildCase(403, "ARR403", "jdoe");

        StringBuilder body = new StringBuilder();
        emailService.appendCaseInfo(body, c);

        String result = body.toString();
        assertThat(result).contains("Case ID: 403");
        assertThat(result).contains("Arrest ID: ARR403");
        assertThat(result).contains("Request Dt:");
        assertThat(result).contains("Case Status: In Progress");
        assertThat(result).contains("Due Dt:");
    }
}
