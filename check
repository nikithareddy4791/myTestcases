@Test
@WithMockUser
void createCaseByArrest_invalidArrestException_returns500() throws Exception {
    when(caseService.createCase(any(CreateCaseRequest.class)))
            .thenThrow(new InvalidArrestException("Invalid arrest"));

    mockMvc.perform(post("/case")
            .contentType(MediaType.APPLICATION_JSON)
            .accept(MediaType.APPLICATION_JSON)
            .content("{}"))
            .andExpect(status().isInternalServerError());
}

@Test
@WithMockUser
void createCaseByArrest_noAcceptHeader_returns501() throws Exception {
    mockMvc.perform(post("/case")
            .contentType(MediaType.APPLICATION_JSON)
            .content("{}"))
            .andExpect(status().isNotImplemented());
}

