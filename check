@Service
public class ReferenceDataService {
    @Autowired
    private ADAListRepository adaListRepository;

    @Autowired
    private CategoryListRepository categoryListRepository;

    @Autowired
    private TagListRepository tagListRepository;

    @Autowired
    private ItemListRepository itemListRepository;

    @Autowired
    private StatusListRepository statusListRepository;

    @Autowired
    private DDDOfficeListRepository dddOfficeListRepository;

    @Autowired
    private CodeRefRepository codeRefRepository;

    @Autowired
    private AuthenticationService authenticationService;

    @Autowired
    private CacheService cacheService;

    @Autowired
    private ModelMapper modelMapper;

    private static final Logger log = LoggerFactory.getLogger(ReferenceDataService.class);

    @Cacheable("dddCodeRef")
    public List<ReferenceCode> getRefCodeByType(final String codeType) {
        return codeRefRepository.findDTOByCodeTypeOrderByIdAsc(codeType);
    }

    @Cacheable("adaList")
    public List<ADA> getAllAdas(Integer dddOfficeId) {
        List<AdaList> adaList = new ArrayList<AdaList>();
        if (dddOfficeId != null) {
            adaList = adaListRepository.findByDdd_Id(dddOfficeId);
        } else {
            adaList = adaListRepository.findAll();
        }
        List<ADA> ret = new ArrayList<ADA>();
        for (AdaList ada : adaList) {
            ret.add(modelMapper.map(ada, ADA.class));
        }
        return ret;
    }

    public List<ADA> updateAdas(final List<ADA> adas) {
        for (ADA ada : adas) {
            AdaList adaEntity = adaListRepository.findById(ada.getId()).orElse(null);
            if (adaEntity != null) {
                modelMapper.map(ada, adaEntity);
                if (ada.getDdd() != null) {
                    DddOfficeList ddd = dddOfficeListRepository.findById(ada.getDdd().getId()).orElse(null);
                    if (ddd != null && (adaEntity.getDdd() == null || adaEntity.getDdd().getId() != ddd.getId())) {
                        adaEntity.setDdd(ddd);
                    }
                }
            } else {
                adaEntity = new AdaList();
                adaEntity = modelMapper.map(ada, AdaList.class);
                if (ada.getDdd() != null && ada.getDdd().getId() > 0) {
                    DddOfficeList ddd = dddOfficeListRepository.findById(ada.getDdd().getId()).orElse(null);
                    if (ddd != null) {
                        adaEntity.setDdd(ddd);
                    }
                }
            }
            adaListRepository.save(adaEntity);
        }
        cacheService.clearCache("adaList");
        return getAllAdas(null);
    }

    @Cacheable("tagList")
    public List<Tag> getAllTags() {
        return tagListRepository.findAllDTO();
    }

    public List<Tag> updateTags(final List<Tag> tags) {
        for (Tag tag : tags) {
            TagList tagEntity = tagListRepository.findById(tag.getId()).orElse(null);
            if(tagEntity!=null){
                modelMapper.map(tag, tagEntity);
            } else {
                tagEntity = new TagList();
                tagEntity = modelMapper.map(tag, TagList.class);
            }
            tagListRepository.save(tagEntity);
        }
        cacheService.clearCache("tagList");
        return getAllTags();
    }

    @Cacheable("categoryList")
    public List<Category> getAllCategories() {
        authenticationService.debug();
        return categoryListRepository.findAllDTO();
    }

    public List<Category> updateCategories(final List<Category> categories) {
        for (Category category : categories) {
            CategoryList categoryEntity = categoryListRepository.findById(category.getId()).orElse(null);
            if(categoryEntity!=null){
                modelMapper.map(category, categoryEntity);
            } else {
                categoryEntity = new CategoryList();
                categoryEntity = modelMapper.map(category, CategoryList.class);
            }
            categoryListRepository.save(categoryEntity);
        }
        cacheService.clearCache("categoryList");
        return getAllCategories();
    }

    @Cacheable("itemList")
    public List<Item> getAllItems() {
        return itemListRepository.findAllDTO();
    }

    public List<Item> updateItems(final List<Item> items) {
        for (Item item : items) {
            ItemList itemEntity = itemListRepository.findById(item.getId()).orElse(null);
            if(itemEntity!=null){
                modelMapper.map(item, itemEntity);
            } else {
                itemEntity = new ItemList();
                itemEntity = modelMapper.map(item, ItemList.class);
            }
            itemListRepository.save(itemEntity);
        }
        cacheService.clearCache("itemList");
        return getAllItems();
    }

    @Cacheable("statusList")
    public List<Status> getAllStatuses() {
        return statusListRepository.findAllDTO();
    }

    @Cacheable("userDddOfficeList")
    public List<DDDOffice> getDDDOffices(final String username) {
        if (authenticationService.isSupervisor()) {
            return dddOfficeListRepository.findAllDTO();
        } else {
            List<DDDOffice> results = new ArrayList<>();
            Authentication auth = SecurityContextHolder.getContext().getAuthentication();
            auth.getAuthorities().forEach(authority -> {
                if (authority.getAuthority().startsWith("ROLE_SG-DDD")) {
                    results.addAll(dddOfficeListRepository.findAllDTOForSG(authority.getAuthority()));
                }
            });
            return results;
        }
    }

    @Cacheable("dddOfficeList")
    public List<DDDOffice> getAllDDDOffices() {
        return dddOfficeListRepository.findAllDTO();
    }
}





