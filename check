#  This is the baseline build file of the current build process, all 
#  projects should import this file to execute their builds and only add 
#  Necessary steps for dependencies or "additional" non standard tasks

# Build Notes

# this script should be included in your local file like this:

# Include the master build script
# include:
#   - project: 'Application/DevOps/cicd-pipeline-scripts'
#     ref: uat 
#     file: '.gitlab-ci.yml'

variables:
# These variables should be set by the .gitlab-ci.yml file in the application directory
  APP_NAME_VAR: "<App name>" # not used here I don't think.

# Prevent GitLab from cleaning mounted volumes and artifacts
  GIT_CLEAN_FLAGS: "none"

# This variable needs to be set if this is a change request build and this is set
# when executing the build

  CHG: ""

# variable can be set to put the ear in a certain git folder
# will got to uat or dev if that is the branch
# for developer branches, or not standard will go to dev folder
  GIT_FOLDER: ""
  
  BASE_IMAGE: "gitlab.nnnn.org:8443/devops/nnnncr/maven"
  IMAGE_TAG: "3.9-eclipse-temurin-21-alpine-2026-01"

# these are variables used by this build process

  CHANGE_REQUEST: ""
  DSTAMP_FORMAT: "%Y%m%d"
  GIT_DIRECTORY_NAME: "was_ear_files"

# this variable for the deploy group:
  group_names: "uat"
  dev_group_names: "dev"

# this variable controls the build reporting
  no_reports: "false"
  report_sonarqube: "true"
  no_deploy: "false"

# when true, deploy jobs run on dev branch (set in project CI/CD variables to enable)
  dev_deploy: "false"

#
  wlp_apps: ""

# These are variable that contain system information used by this process

  CURRENT_BRANCH_NAME: "$CI_COMMIT_BRANCH"
  PKG_EAR: "false"
  LC_BRANCH: "$CURRENT_BRANCH_NAME"
  DEFAULT_BRANCH_NAME: "$CI_DEFAULT_BRANCH"
  COMMIT_BRANCH: "$CI_COMMIT_BRANCH"
  DATESTAMP: $CI_JOB_STARTED_AT
  CI_REGISTRY_PASSWORD: "$CI_JOB_TOKEN"
  VERSION: "1.0.$CI_PIPELINE_ID" # Customize this as needed
  SONAR_LOGIN: "sqa_90c7e39bf72f800817d8522ca900f0d46fce6abb"
  SONAR_TOKEN: "sqa_36b3200a5cb78b4c130314af86baf56d2e95d3fa"
  HTTPS_TRUSTSTORE: "/etc/gitlab-runner/certs"
  MAVEN_OPTS: >-
    -Dhttps.protocols=TLSv1.2
    -Dmaven.repo.local=.m2/repository
    -Dorg.slf4j.simpleLogger.log.org.apache.maven.cli.transfer.Slf4jMavenTransferListener=WARN
    -Dorg.slf4j.simpleLogger.showDateTime=true
    -Djava.awt.headless=true

  # As of Maven 3.3.0 instead of this you may define these options in `.mvn/maven.config` so the same config is used
  # when running from the command line.
  # `installAtEnd` and `deployAtEnd` are only effective with recent version of the corresponding plugins.
  MAVEN_CLI_X: >-
    -s /maven-config/unsecure_settings.xml  
    
  MAVEN_CLI_OPTS: >-
     --batch-mode
     --errors
     --fail-at-end
     --show-version
     -s /maven-config/ci_settings.xml
    
  MAVEN_CLI_X_OPTS: >-
     --batch-mode
     --errors
     --fail-at-end
     --show-version
     -s /maven-config/unsecure_settings.xml  
    
  #DOCKER_AUTH_CONFIG: >
  #  {
  #    "auths": {
  #      "gitlab.nnnn.org:8443": {
  #        "auth": "di13aW5pZXdpY3oxOmdscGF0LUJGYW80NUd5RHFqOGp5aG9SY1N4"
  #      }
  #    }
  #  }
 

# set the datestamp to be used by the dynamic ear name
.dstamp_script: 
  - dstamp="$(date -d "$DATESTAMP" +"$DSTAMP_FORMAT")"
  - echo $dstamp

.dget_branch_name:
  - echo $LC_BRANCH
  - LC_BRANCH=$(echo "$LC_BRANCH" | tr '[:upper:]' '[:lower:]')
  - echo $LC_BRANCH
  - if [[ $LC_BRANCH == *"_d"  ||  $LC_BRANCH == *"dev" ]]; then BRANCH="dev"; else BRANCH="$LC_BRANCH"; fi
  - if [[ $GIT_FOLDER == "" ]]; then if [[ $LC_BRANCH == "uat" ]]; then GIT_FOLDER="$LC_BRANCH"; else GIT_FOLDER="dev"; fi fi
  - if [[ LC_BRANCH == "" ]]; then LC_BRANCH=$CI_MERGE_REQUEST_SOURCE_BRANCH_NAME; fi
  - echo $BRANCH
  - echo $LC_BRANCH
  - echo $GIT_FOLDER
  
# List of stages for jobs, and their order of execution
# note all jobs in a stage need to execute before the next stage
# we have added triggers than before build, so if your project has dependencies that 
# need to be there, add them as a trigger job before the main build
stages:
  - preset
  - triggers
  - build
  - verify
  - release
  - deploy
# setup-items
# this job sets up some variable names and cleans up the ear directory to prevent 
# previously failed ears from being commited to the was_ear repo

setup-items:
  stage: preset
  tags:
    - was
  script:
    - echo $CHANGE_REQUEST
    - echo $CHG
    - if [ "$CHANGE_REQUEST" == "" ]; then CHANGE_REQUEST=$CHG; else echo " CHANGE_REQUEST is blank "; fi
    - echo $CHANGE_REQUEST
    - echo $CHG
  rules: 
    - when: always

  

build:
  stage: build
  image: "$BASE_IMAGE:$IMAGE_TAG"
  tags:
    - podman
  script:
    #- if [ "$CHANGE_REQUEST" == "" ]; then CHANGE_REQUEST=$CHG; VERSION="$VERSION-$CHG"; else echo " CHANGE_REQUEST is blank "; fi
    #- echo $CHANGE_REQUEST
    - echo "checking verions:" + $VERSION
    # Build and package without running tests - tests will run in verify stage
    - mvn $MAVEN_CLI_X_OPTS clean install -DskipTests

  cache:
    key: "maven-$CI_COMMIT_REF_SLUG"
    paths:
      - .sonar/cache
      - "**/target/"
  artifacts:
    name: "Maven artifacts from $CI_PROJECT_NAME on $CI_COMMIT_REF_SLUG"
    paths:
      - "**/target/*.war"
      - "**/target/*.ear"
      - "**/target/*.jar"
      - "**/target/surefire-reports/"
    reports:
      junit:
        - "**/target/surefire-reports/TEST-*.xml"
    expire_in: 2 weeks
  rules: 
    - when: always

sonarqube-check:
  image: "$BASE_IMAGE:$IMAGE_TAG"
  tags:
    - podman
  needs:
    - job: build
      artifacts: true

  stage: verify
  cache:
    key: "maven-$CI_COMMIT_REF_SLUG"
    paths:
      - .sonar/cache
  script:
    - echo $no_reporting
    - echo $CI_PIPELINE_TRIGGERED
    - echo $CI_JOB_NAME
    # Run tests and perform SonarQube analysis
    - mvn  $MAVEN_CLI_X_OPTS verify org.sonarsource.scanner.maven:sonar-maven-plugin:5.0.0.4389:sonar -Dsonar.qualitygate.wait=true -Dsonar.host.url=http://sps2-wisegw01d:9000  -Dsonar.token=${SONAR_TOKEN} -Dsonar.junit.reportPaths=target/surefire-reports  -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml

  artifacts:
    name: "Test and Coverage Reports from $CI_PROJECT_NAME on $CI_COMMIT_REF_SLUG"
    paths:
      - "**/target/surefire-reports/"
      - "**/target/site/jacoco/"
      - "**/target/jacoco.exec"
    reports:
      junit:
        - "**/target/surefire-reports/TEST-*.xml"
    expire_in: 2 weeks
    when: always

  rules:
    - if: $report_sonarqube == "true"
  allow_failure: true

pmd-report:
  image: "$BASE_IMAGE:$IMAGE_TAG"
  tags:
    - podman
  stage: verify
  needs:
    - job: build
      artifacts: true
  script:
    - mvn $MAVEN_CLI_X_OPTS pmd:pmd 
  artifacts:
    name: "Maven artifacts from $CI_PROJECT_NAME on $CI_COMMIT_REF_SLUG"
    paths:
      - "**/target/reports"
    expire_in: 2 weeks
  rules:
    - if: $no_reports != "true"
  allow_failure: true

dependency-check:
  image: "$BASE_IMAGE:$IMAGE_TAG"
  tags:
    - podman
  stage: verify
  needs:
    - job: build
      artifacts: true

  rules:
    - if: $no_reports != "true"
  variables:
    JSREPO_PATH: ".m2/repository/org/owasp/dependency-check-utils/6.1.1/../../dependency-check-data/5.0" 
  script:
    - mkdir -p ${JSREPO_PATH}
    - cp /dependency-check/jsrepository.json ${JSREPO_PATH}/.
    - mvn  $MAVEN_CLI_X_OPTS dependency-check:check  
  artifacts:
    name: "Maven artifacts from $CI_PROJECT_NAME on $CI_COMMIT_REF_SLUG"
    paths:
      - "**/target/dependency-check-report.html"
   
    expire_in: 2 weeks
  allow_failure: true

upload-war:
  image: "$BASE_IMAGE:$IMAGE_TAG"
  stage: release
  tags:
    - podman
  needs:
    - job: build
      artifacts: true
  before_script:
    - export LC_BRANCH="${CI_COMMIT_REF_NAME//\//-}"
    - !reference [.dstamp_script]
    - !reference [.dget_branch_name]
    - VERSION="${dstamp}-${LC_BRANCH}"
    - if [[ $CHANGE_REQUEST =~ ^CHG ]]; then VERSION="${dstamp}-${CHANGE_REQUEST}" ; fi
    - if [[ $CHG =~ ^CHG ]]; then VERSION="${dstamp}-${CHG}"; fi
    - group_id=$(mvn $MAVEN_CLI_X help:evaluate -Dexpression=project.groupId -q -DforceStdout)
    - artifact_id=$(mvn $MAVEN_CLI_X help:evaluate -Dexpression=project.artifactId -q -DforceStdout)
  script:
    - echo $VERSION
    - 'mvn $MAVEN_CLI_X_OPTS versions:set -DnewVersion=$VERSION'
    - 'mvn $MAVEN_CLI_X_OPTS versions:commit'
    - echo "==== ${group_id}:${artifact_id}:${VERSION} ===="
    - 'mvn $MAVEN_CLI_X_OPTS deploy -DskipTests'
    - echo "==== ${group_id}:${artifact_id}:${VERSION} (published) ===="
  rules: 
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
      when: never
    - if: $PKG_EAR == "false"

upload-ear:
  image: "$BASE_IMAGE:$IMAGE_TAG"
  stage: release
  tags:
    - podman
  needs:
    - job: build
      artifacts: true
  before_script:
    - export LC_BRANCH="${CI_COMMIT_REF_NAME//\//-}"
    - !reference [.dstamp_script]
    - !reference [.dget_branch_name]
    - VERSION="${dstamp}-${LC_BRANCH}"
    - if [[ $CHANGE_REQUEST =~ ^CHG ]]; then VERSION="${dstamp}-${CHANGE_REQUEST}" ; fi
    - if [[ $CHG =~ ^CHG ]]; then VERSION="${dstamp}-${CHG}"; fi   
  script:
    - echo $VERSION
    - 'mvn $MAVEN_CLI_X_OPTS versions:set -DnewVersion=1.0.1W'
    - 'mvn $MAVEN_CLI_X_OPTS versions:commit'
    - 'mvn $MAVEN_CLI_X_OPTS versions:set -DnewVersion=$VERSION -f ear-pom.xml'
    - 'mvn $MAVEN_CLI_X_OPTS versions:commit -f ear-pom.xml'
    - group_id=$(mvn $MAVEN_CLI_X help:evaluate -Dexpression=project.groupId -q -DforceStdout)
    - artifact_id=$(mvn $MAVEN_CLI_X help:evaluate -Dexpression=project.artifactId -q -DforceStdout)
    - echo "==== ${group_id}:${artifact_id}:${VERSION} ===="
    - 'mvn $MAVEN_CLI_X_OPTS deploy -DskipTests'
    - echo "==== ${group_id}:${artifact_id}:${VERSION} (published) ===="
    - sed -i "s|000000|1.0.1W|g" src/main/application/META-INF/application.xml
    - ear_group_id=$(mvn $MAVEN_CLI_X help:evaluate -Dexpression=project.groupId -q -DforceStdout -f ear-pom.xml)
    - ear_artifact_id=$(mvn $MAVEN_CLI_X help:evaluate -Dexpression=project.artifactId -q -DforceStdout -f ear-pom.xml)
    - echo "==== ${ear_group_id}:${ear_artifact_id}:${VERSION} ===="
    - 'mvn $MAVEN_CLI_X_OPTS deploy -f ear-pom.xml'
    - echo "==== ${ear_group_id}:${ear_artifact_id}:${VERSION} (published) ===="
  rules: 
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
      when: never
    - if: $PKG_EAR == "true"



deploy-websphere:
  image: "$BASE_IMAGE:$IMAGE_TAG"
  stage: deploy
  tags: 
    - podman
  rules:
    - if: '$no_deploy == "true"'
      when: never
    - if: '$wlp_apps != ""'
      when: never
    - if: ($CHANGE_REQUEST == "" && $CHG == "" && $CI_COMMIT_BRANCH == "uat")
    - if: ($CHANGE_REQUEST == "" && $CHG == "" && $CI_COMMIT_BRANCH == "dev" && $dev_deploy == "true")
  before_script:
    - echo "wlp_apps"
    - echo $wlp_apps
    - export LC_BRANCH="${CI_COMMIT_REF_NAME//\//-}"
    - !reference [.dstamp_script]
    - !reference [.dget_branch_name]
    - version_id="${dstamp}-${LC_BRANCH}"
    - if [[ $CHANGE_REQUEST =~ ^CHG ]]; then version_id="${dstamp}-${CHANGE_REQUEST}" ; fi
    - if [[ $CHG =~ ^CHG ]]; then version_id="${dstamp}-${CHG}"; fi   
    - group_id=$(mvn $MAVEN_CLI_X help:evaluate -Dexpression=project.groupId -q -DforceStdout -f ear-pom.xml)
    - artifact_id=$(mvn $MAVEN_CLI_X help:evaluate -Dexpression=project.artifactId -q -DforceStdout -f ear-pom.xml)
    - ear_name="${group_id}:${artifact_id}:${version_id}"
    - |
      if [[ "$CI_COMMIT_BRANCH" == "dev" ]]; then
        group_names="${dev_group_names}"
      fi
      if [[ -n "${group_names}" ]]; then
         group_names_string='"group_names": "'${group_names}'"'
      else
         group_names_string=''
      fi
      echo ${group_names_string}
    - |
      echo '{ 
        "extra_vars": { 
          "repo_used": "maven", 
          "name_of_ear": "'"${ear_name}"'",
          '${group_names_string}'
        } 
      }' > payload.json
  script:
    - echo $ear_name
    - cat payload.json
    - >
      curl -X POST https://tower.nnnn.org/api/v2/job_templates/970/launch/ 
      -H "Content-Type: application/json" 
      -H "Authorization: Basic c3ZjX2NvYmFsdC1hZDpDMGJhbHRSQkR1Y2tpM3M=" 
      -d @payload.json 

