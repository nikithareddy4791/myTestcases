    @Cacheable("dddCodeRef")
    public List<ReferenceCode> getRefCodeByType(final String codeType) {
        return codeRefRepository.findDTOByCodeTypeOrderByIdAsc(codeType);
    }

    @Cacheable("adaList")
    public List<ADA> getAllAdas() {
        List<AdaList> adaList = adaListRepository.findAll(); 
        List<ADA> ret = new ArrayList<ADA>();
        for(AdaList ada:adaList){
            ret.add(modelMapper.map(ada, ADA.class));
        }
        return ret;
    }

    public List<ADA> updateAdas(final List<ADA> adas) {
        for (ADA ada : adas) {
            AdaList adaEntity = adaListRepository.findById(ada.getId()).orElse(null);
            if(adaEntity!=null){
                modelMapper.map(ada, adaEntity);
            } else {
                adaEntity = new AdaList();
                adaEntity = modelMapper.map(ada, AdaList.class);
            }
            adaListRepository.save(adaEntity);
        }
        cacheService.clearCache("adaList");
        return getAllAdas();
    }

