    // =========================================================================
    // POST /case/intake — getCaseIntakeList() — complete method (line 179)
    // =========================================================================

    @Test
    @WithMockUser
    @DisplayName("POST /case/intake - returns 200 with intake list")
    void getCaseIntakeList_success_returns200() throws Exception {
        IntakeListResponse response = new IntakeListResponse();
        response.setIntakeArrests(List.of(new ArrestInfo()));
        when(caseService.getIntakeArrests(any())).thenReturn(response);

        IntakeFilter filter = new IntakeFilter();
        filter.setArrDtFrom("2024-01-01");
        filter.setArrDtTo("2024-12-31");

        mockMvc.perform(post("/case/intake")
                .with(csrf())
                .contentType(MediaType.APPLICATION_JSON)
                .accept(MediaType.APPLICATION_JSON)
                .content(objectMapper.writeValueAsString(filter)))
                .andExpect(status().isOk());

        verify(caseService).getIntakeArrests(any());
    }

    @Test
    @WithMockUser
    @DisplayName("POST /case/intake - returns empty list when no arrests found")
    void getCaseIntakeList_noResults_returnsEmptyList() throws Exception {
        IntakeListResponse response = new IntakeListResponse();
        response.setIntakeArrests(Collections.emptyList());
        when(caseService.getIntakeArrests(any())).thenReturn(response);

        IntakeFilter filter = new IntakeFilter();
        filter.setArrDtFrom("2024-01-01");
        filter.setArrDtTo("2024-01-31");

        mockMvc.perform(post("/case/intake")
                .with(csrf())
