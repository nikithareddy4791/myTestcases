@ExtendWith(MockitoExtension.class)
@DisplayName("CDWRepository Tests")
public class CDWRepositoryTest {

    @Mock
    private EntityManager entityManager;

    @Mock
    private PrinthubUtil printhubUtil;

    @Mock
    private AuthenticationService authenticationService;

    @Mock
    private Query query;

    @InjectMocks
    private CDWRepository cdwRepository;

    private static final String ARR_ID = "ARR001";
    private static final Date ARR_DATE = Date.valueOf(LocalDate.of(2024, 1, 15));

    @BeforeEach
    void setUp() {
        lenient().when(printhubUtil.getReportUrl(any())).thenReturn("http://mock-url");
        lenient().when(authenticationService.hasSealedAccess()).thenReturn(true);
    }

    // =========================================================================
    // Helper — builds raw result list the same way JPA native query returns it
    // =========================================================================

    @SuppressWarnings({"unchecked", "rawtypes"})
    private List buildRawResultList(Object[]... rows) {
        List list = new ArrayList();
        for (Object[] row : rows) {
            list.add(row);
        }
        return list;
    }

    private Object[] buildRow(String arrId, String topCharge, Date arrDt,
                               String frstNm, String lastNm,
                               String nysid, Character sealedFlg) {
        return new Object[]{arrId, topCharge, arrDt, frstNm, lastNm, nysid, sealedFlg, null};
    }

    // =========================================================================
    // getArrestInfo(String arrId)
    // =========================================================================

    @Nested
    @DisplayName("getArrestInfo(String)")
    class GetArrestInfoSingleTests {

        @Test
        @DisplayName("calls createNativeQuery with ArrestInfo class")
        void getArrestInfo_callsCreateNativeQuery() {
            ArrestInfo expected = new ArrestInfo();
            when(entityManager.createNativeQuery(anyString(), eq(ArrestInfo.class))).thenReturn(query);
            when(query.setParameter(eq(1), any())).thenReturn(query);
            when(query.getSingleResult()).thenReturn(expected);

            ArrestInfo result = cdwRepository.getArrestInfo(ARR_ID);

            verify(entityManager).createNativeQuery(anyString(), eq(ArrestInfo.class));
            assertThat(result).isEqualTo(expected);
        }

        @Test
        @DisplayName("sets parameter 1 to arrId")
        void getArrestInfo_setsArrIdParameter() {
            ArrestInfo expected = new ArrestInfo();
            when(entityManager.createNativeQuery(anyString(), eq(ArrestInfo.class))).thenReturn(query);
            when(query.setParameter(eq(1), any())).thenReturn(query);
            when(query.getSingleResult()).thenReturn(expected);

            cdwRepository.getArrestInfo(ARR_ID);

            verify(query).setParameter(1, ARR_ID);
        }

        @Test
        @DisplayName("returns result from getSingleResult")
        void getArrestInfo_returnsSingleResult() {
            ArrestInfo expected = new ArrestInfo();
            when(entityManager.createNativeQuery(anyString(), eq(ArrestInfo.class))).thenReturn(query);
            when(query.setParameter(eq(1), any())).thenReturn(query);
            when(query.getSingleResult()).thenReturn(expected);

            assertThat(cdwRepository.getArrestInfo(ARR_ID)).isSameAs(expected);
        }
    }

    // =========================================================================
    // getArrestInfoSummary(List<String>)
    // =========================================================================

    @Nested
    @DisplayName("getArrestInfoSummary(List<String>)")
    class GetArrestInfoSummaryListTests {

        @Test
        @DisplayName("returns empty list when no results")
        @SuppressWarnings("rawtypes")
        void getArrestInfoSummary_list_emptyResults_returnsEmptyList() {
            when(entityManager.createNativeQuery(anyString(), eq(ArrestInfo.class))).thenReturn(query);
            when(query.setParameter(eq(1), any())).thenReturn(query);
            when(query.getResultList()).thenReturn(Collections.emptyList());

            List<ArrestInfo> result = cdwRepository.getArrestInfoSummary(List.of(ARR_ID));

            assertThat(result).isEmpty();
        }

        @Test
        @DisplayName("returns results from query")
        @SuppressWarnings({"rawtypes", "unchecked"})
        void getArrestInfoSummary_list_returnsResults() {
            ArrestInfo info = new ArrestInfo();
            info.setArrId(ARR_ID);
            List results = List.of(info);

            when(entityManager.createNativeQuery(anyString(), eq(ArrestInfo.class))).thenReturn(query);
            when(query.setParameter(eq(1), any())).thenReturn(query);
            when(query.getResultList()).thenReturn(results);

            List<ArrestInfo> result = cdwRepository.getArrestInfoSummary(List.of(ARR_ID));

            assertThat(result).hasSize(1);
            assertThat(result.get(0).getArrId()).isEqualTo(ARR_ID);
        }

        @Test
        @DisplayName("sets parameter 1 to arrIds list")
        @SuppressWarnings("rawtypes")
        void getArrestInfoSummary_list_setsParameter() {
            List<String> arrIds = List.of("ARR001", "ARR002");
            when(entityManager.createNativeQuery(anyString(), eq(ArrestInfo.class))).thenReturn(query);
            when(query.setParameter(eq(1), any())).thenReturn(query);
            when(query.getResultList()).thenReturn(Collections.emptyList());

            cdwRepository.getArrestInfoSummary(arrIds);

            verify(query).setParameter(1, arrIds);
        }

        @Test
        @DisplayName("calls getResultList not getSingleResult")
        @SuppressWarnings("rawtypes")
        void getArrestInfoSummary_list_callsGetResultList() {
            when(entityManager.createNativeQuery(anyString(), eq(ArrestInfo.class))).thenReturn(query);
            when(query.setParameter(eq(1), any())).thenReturn(query);
            when(query.getResultList()).thenReturn(Collections.emptyList());

            cdwRepository.getArrestInfoSummary(List.of(ARR_ID));

            verify(query).getResultList();
            verify(query, never()).getSingleResult();
        }

        @Test
        @DisplayName("masks info when user has no sealed access")
        @SuppressWarnings({"rawtypes", "unchecked"})
        void getArrestInfoSummary_noSealedAccess_masksInfo() {
            when(authenticationService.hasSealedAccess()).thenReturn(false);

            ArrestInfo info = new ArrestInfo();
            info.setArrId(ARR_ID);
            info.setArrSealedFlg("Y");
            info.setDeftFrstNm("John");
            info.setDeftLastNm("Doe");
            List results = List.of(info);

            when(entityManager.createNativeQuery(anyString(), eq(ArrestInfo.class))).thenReturn(query);
            when(query.setParameter(eq(1), any())).thenReturn(query);
            when(query.getResultList()).thenReturn(results);

            List<ArrestInfo> result = cdwRepository.getArrestInfoSummary(List.of(ARR_ID));

            // maskInfo() should have been called — name should be masked
            assertThat(result.get(0).getDeftFrstNm()).isNotEqualTo("John");
        }
    }

    // =========================================================================
    // getMaskedArrestInfoSummary — tested via getArrestInfoSummary with no sealed access
    // =========================================================================

    @Nested
    @DisplayName("getMaskedArrestInfoSummary(List<String>)")
    class GetMaskedArrestInfoSummaryTests {

        @Test
