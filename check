    void getCaseById_noAcceptHeader_returns501() throws Exception {
        when(caseService.loadCase(100)).thenReturn(new DDDCase());
        mockMvc.perform(get("/case/100"))
                .andExpect(status().isNotImplemented());
    }

    // =========================================================================
    // POST /case/intake — getCaseIntakeList() — line 179
    // =========================================================================

    @Test
    @DisplayName("POST /case/intake - returns 200 with intake list (line 179)")
    void getCaseIntakeList_success_returns200() throws Exception {
        IntakeListResponse response = new IntakeListResponse();
        response.setIntakeArrests(List.of(new ArrestInfo()));
        when(caseService.getIntakeArrests(any())).thenReturn(response);

        mockMvc.perform(post("/case/intake")
                .contentType(MediaType.APPLICATION_JSON)
                .accept(MediaType.APPLICATION_JSON)
                .content(validIntakeFilterJson()))
                .andExpect(status().isOk());

        verify(caseService).getIntakeArrests(any());
    }

    @Test
    @DisplayName("POST /case/intake - exception returns 500")
    void getCaseIntakeList_exception_returns500() throws Exception {
        when(caseService.getIntakeArrests(any()))
                .thenThrow(new RuntimeException("CDW error"));

        mockMvc.perform(post("/case/intake")
                .contentType(MediaType.APPLICATION_JSON)
                .accept(MediaType.APPLICATION_JSON)
                .content(validIntakeFilterJson()))
                .andExpect(status().isInternalServerError());
    }

    @Test
    @DisplayName("POST /case/intake - no Accept header returns 501")
    void getCaseIntakeList_noAcceptHeader_returns501() throws Exception {
        mockMvc.perform(post("/case/intake")
                .contentType(MediaType.APPLICATION_JSON)
                .content(validIntakeFilterJson()))
                .andExpect(status().isNotImplemented());

        verify(caseService, never()).getIntakeArrests(any());
    }

    // =========================================================================
    // GET /case/{caseId}/file/{uploadId} — getCaseUploadById()
    // =========================================================================

    @Test
    @DisplayName("GET /case/{caseId}/file/{uploadId} - returns 200 with file")
    void getCaseUploadById_found_returns200() throws Exception {
        ByteArrayResource resource = new ByteArrayResource("content".getBytes());
        when(caseService.getFile(100, 1))
                .thenReturn(new Object[]{"document.pdf", resource});

        mockMvc.perform(get("/case/100/file/1")
                .accept(MediaType.APPLICATION_JSON))
                .andExpect(status().isOk())
                .andExpect(header().string("Content-Disposition",
                        containsString("document.pdf")));
    }

    @Test
    @DisplayName("GET /case/{caseId}/file/{uploadId} - exception returns 500")
    void getCaseUploadById_exception_returns500() throws Exception {
        when(caseService.getFile(100, 1))
                .thenThrow(new RuntimeException("S3 error"));

        mockMvc.perform(get("/case/100/file/1")
                .accept(MediaType.APPLICATION_JSON))
                .andExpect(status().isInternalServerError());
    }

    @Test
    @DisplayName("GET /case/{caseId}/file/{uploadId} - no Accept header returns 501")
    void getCaseUploadById_noAcceptHeader_returns501() throws Exception {
        when(caseService.getFile(100, 1))
                .thenReturn(new Object[]{"doc.pdf", new ByteArrayResource(new byte[0])});

        mockMvc.perform(get("/case/100/file/1"))
                .andExpect(status().isNotImplemented());
    }

    // =========================================================================
    // DELETE /case/{caseId}/file/{uploadId} — deleteCaseUploadById() — line 193
    // deleteFile() always throws FileDeleteException (production bug).
    // GlobalExceptionHandler catches FileDeleteException → 500.
    // Line 193 (caseService.deleteFile call) IS covered when the method is entered.
    // =========================================================================

    @Test
    @DisplayName("DELETE /case/{caseId}/file/{uploadId} - FileDeleteException → 500 (line 193)")
    void deleteCaseUploadById_fileDeleteException_returns500() throws Exception {
        doThrow(new FileDeleteException("Failed to delete file 1"))
                .when(caseService).deleteFile(100, 1);

        mockMvc.perform(delete("/case/100/file/1")
                .accept(MediaType.APPLICATION_JSON))
                .andExpect(status().isInternalServerError());

        verify(caseService).deleteFile(100, 1);
    }

    @Test
    @DisplayName("DELETE /case/{caseId}/file/{uploadId} - no Accept header returns 501")
    void deleteCaseUploadById_noAcceptHeader_returns501() throws Exception {
        mockMvc.perform(delete("/case/100/file/1")
                .andExpect(status().isNotImplemented());

        verify(caseService, never()).deleteFile(anyInt(), anyInt());
    }

    @Test
    @DisplayName("DELETE /case/{caseId}/file/{uploadId} - no auth still calls deleteFile (filters disabled)")
    void deleteCaseUploadById_noAuth_returns401() throws Exception {
        doThrow(new FileDeleteException("Failed to delete file 1"))
                .when(caseService).deleteFile(100, 1);

        mockMvc.perform(delete("/case/100/file/1")
                .accept(MediaType.APPLICATION_JSON))
                .andExpect(status().isInternalServerError());
    }

    // =========================================================================
    // GET /case/stats — getCaseStats() — lines 227-231
    // =========================================================================

    @Test
    @DisplayName("GET /case/stats - returns 200 with stats (lines 227-231)")
    void getCaseStats_success_returns200() throws Exception {
        DDDCaseStats stats = new DDDCaseStats();
        stats.setOverdueCount(3);
        stats.setComingDueCount(2);

        when(authenticationService.getUsername()).thenReturn("jdoe");
        when(caseService.getCaseStats("jdoe")).thenReturn(stats);

        mockMvc.perform(get("/case/stats")
                .accept(MediaType.APPLICATION_JSON))
                .andExpect(status().isOk());

        verify(caseService).getCaseStats("jdoe");
    }

    @Test
    @DisplayName("GET /case/stats - exception returns 500")
    void getCaseStats_exception_returns500() throws Exception {
        when(authenticationService.getUsername()).thenReturn("jdoe");
        when(caseService.getCaseStats("jdoe"))
